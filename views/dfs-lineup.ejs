<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/site-head") %>
    <title>DFS Lineup — Marlboro Men's Softball</title>
  </head>
  <body>
    <%- include("partials/site-header") %>

    <main class="page-main dfs-page<%= slate && !slate.canEdit ? ' dfs-page--readonly' : '' %>">
      <div class="dfs-page-head">
        <h1 class="page-title">DFS Lineup Builder</h1>
        <div class="dfs-page-head-actions">
          <div class="dfs-info-wrap">
            <button
              type="button"
              class="dfs-info-btn"
              id="dfsIntroBtn"
              aria-label="How DFS lineups work"
              aria-expanded="false"
              aria-controls="dfsIntroPanel"
            >
              <svg class="dfs-info-btn__icon" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">
                <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" />
                <path d="M12 11v5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                <circle cx="12" cy="8" r="1.25" fill="currentColor" />
              </svg>
            </button>
            <div
              id="dfsIntroPanel"
              class="dfs-info-panel"
              role="dialog"
              aria-labelledby="dfsIntroPanelTitle"
              hidden
            >
              <button type="button" class="dfs-info-panel__close" id="dfsIntroClose" aria-label="Close">
                <span aria-hidden="true">×</span>
              </button>
              <h2 class="dfs-info-panel__title" id="dfsIntroPanelTitle">How DFS lineups work</h2>
              <div class="dfs-info-panel__body dfs-intro">
                <p>
                  Build an <strong><%= lineupSize %>-player</strong> lineup for the next slate with a
                  <strong>$<%= salaryCap.toLocaleString() %></strong> salary cap. Salaries weight <strong>offensive rating</strong> (~80%),
                  <strong>opponent runs allowed</strong> (~12%), and the <strong>opposing primary pitcher</strong> (~8%).
                  Player rating leans on <strong>career stats</strong> when available (about 85% career / 15% 2026 when both exist).
                  <strong>Offensive rating</strong> is a <strong>composition of statistical rates</strong> (e.g. damage and run-production measures): each piece is compared to league baselines, then combined with <strong>fixed formula weights</strong>—not a scout’s eye or anyone’s opinion.
                  <strong>Nothing subjective</strong> sets player rankings or DFS prices: no votes, manual tiers, or discretionary ordering—only the underlying stats and the math applied to them.
                  The bottom <strong>20%</strong> of the slate by salary are all priced at <strong>$5,000</strong>. Everyone else is priced on a smooth ladder from <strong>$5,100</strong> up to <strong>$12,000</strong> by offensive rating (no big jumps after the minimum tier).
                  You can browse everything without an account. To compete on the leaderboard, pick any <strong>display name</strong> (up to 24 characters) and save your lineup for <strong>Sunday week slates</strong> (<code>W#</code>) or <strong>Wednesday slates</strong> (<code>D…</code>). <strong>One lineup per device per slate.</strong> When you save to the database, each player’s <strong>salary is locked at that moment</strong> — the leaderboard always shows what you paid, not today’s prices. You can edit and re-save before the deadline; if you change players, new salaries apply on the next save.
                  Only <strong>past slates</strong> (view only) and the <strong>current slate</strong> appear below — future weeks stay hidden until it’s time to set lineups.
                  <strong>Sunday</strong> slates lock at <strong>11:59 PM Eastern the night before games</strong>. <strong>Wednesday</strong> slates lock at <strong>8:00 PM Eastern on game day</strong>.
                </p>
              </div>
            </div>
          </div>
          <a href="<%= sitePath('/dfs/leaderboard') %>" class="dfs-btn dfs-btn--primary">Leaderboard</a>
        </div>
      </div>

      <div class="dfs-lineup-notices" id="dfsLineupNotices">
        <section
          class="dfs-lineup-notice dfs-lineup-notice--compete"
          id="dfsNoticeCompete"
          role="note"
          aria-label="Leaderboard competition"
        >
          <button type="button" class="dfs-notice-dismiss" data-notice-dismiss="compete" aria-label="Dismiss competition notice">
            <span aria-hidden="true">×</span>
          </button>
          <p class="dfs-notice-text">
            <strong>To compete against others,</strong> pick 8 players, enter your name, and press <strong>Submit lineup</strong> before the deadline.
            The <a href="<%= sitePath('/dfs/leaderboard') %>">leaderboard</a> ranks saved lineups — one entry per device per slate.
          </p>
        </section>

        <section
          class="dfs-lineup-notice dfs-lineup-notice--risk"
          id="dfsNoticeRisk"
          role="note"
          aria-label="Lineup disclaimer"
        >
          <button type="button" class="dfs-notice-dismiss" data-notice-dismiss="risk" aria-label="Dismiss lineup disclaimer">
            <span aria-hidden="true">×</span>
          </button>
          <p class="dfs-notice-text">
            <strong>Lineups are at your own risk.</strong> Rosters and schedules here do not guarantee anyone is active for a given slate—players may sit out, be injured, or miss that week for other reasons. Double-check real-world lineups before you lock in picks.
          </p>
        </section>
      </div>

      <% if (typeof firebaseEnabled !== 'undefined' && !firebaseEnabled) { %>
      <section class="dfs-leaderboard-alert dfs-leaderboard-alert--error" role="status">
        <p>
          <strong>Firebase is not configured.</strong>
          Add web app keys to <code>.env</code>, then run <code>npm run build:pages</code> and push the <code>docs/</code> folder for GitHub Pages.
        </p>
      </section>
      <% } %>

      <div class="dfs-slate-form" id="dfsSlateForm">
        <p class="dfs-slate-form-label"><strong>Slate</strong></p>
        <nav class="dfs-slate-picker" aria-label="Choose slate">
          <% slateOptions.forEach((opt) => { %>
          <a
            href="<%= (typeof staticSite !== 'undefined' && staticSite)
              ? sitePath('/dfs/slate/' + encodeURIComponent(opt.value))
              : sitePath('/dfs?slate=' + encodeURIComponent(opt.value)) %>"
            class="dfs-slate-chip<%= opt.value === selectedSlate ? ' is-selected' : '' %><%= opt.canEdit ? ' dfs-slate-chip--open' : ' dfs-slate-chip--locked' %><%= opt.isPast ? ' dfs-slate-chip--past' : '' %>"
            data-slate="<%= opt.value %>"
            <%= opt.value === selectedSlate ? 'aria-current="page"' : '' %>
          ><%= opt.label %><% if (opt.canEdit) { %> · open<% } else { %> · locked<% } %></a>
          <% }) %>
        </nav>
        <input type="hidden" name="lineup" id="lineupInput" value="<%= lineupNorms.join(',') %>" />
      </div>

      <% if (typeof allSlatesLocked !== 'undefined' && allSlatesLocked) { %>
      <p class="dfs-slate-lock-notice dfs-slate-lock-notice--season" role="status">
        The season schedule is complete — all slates are view only. Browse past weeks below or check the <a href="<%= sitePath('/dfs/leaderboard') %>">leaderboard</a>.
      </p>
      <% } else if (slate && slate.isPast && !slate.canEdit) { %>
      <p class="dfs-slate-lock-notice dfs-slate-lock-notice--view" role="status">
        <strong>View only.</strong> The lineup deadline for this slate has passed — review picks and scores below.
        <% if (activeSlateToken) { %>
        <a href="<%= sitePath('/dfs?slate=' + encodeURIComponent(activeSlateToken)) %>" class="dfs-slate-lock-link">Go to open slate</a>
        <% } %>
      </p>
      <% } %>

      <div class="dfs-layout">
        <div class="dfs-top-row">
          <section class="dfs-slate-banner dfs-top-panel" aria-label="Current slate">
            <h2 class="dfs-slate-title"><%= slate ? slate.label : 'No slate' %></h2>
            <% if (!slate) { %>
            <p class="dfs-slate-status">No slates on the schedule.</p>
            <% } else if (slate.canEdit) { %>
            <p class="dfs-slate-status dfs-slate-status--open">
              Open for lineups through <strong><%= slate.lineupLockDeadlineLabel || 'deadline' %></strong><% if (slate.slateType === 'wednesday') { %> (8:00 PM Eastern on game day)<% } else { %> (11:59 PM Eastern the night before games)<% } %> ·
              <%= slate.games.length %> game<%= slate.games.length === 1 ? '' : 's' %> · <%= slate.teamIds.size %> teams
            </p>
            <% } else if (slate.isPast) { %>
            <p class="dfs-slate-status dfs-slate-status--past">View only — lineup deadline passed. Scores appear when results are available for this slate.</p>
            <% } else { %>
            <p class="dfs-slate-status dfs-slate-status--locked">This slate isn’t editable right now.</p>
            <% } %>
            <% if (slate && slate.games && slate.games.length) { %>
            <ul class="dfs-game-list">
              <% slate.games.forEach((g) => { %>
              <li>
                <span class="matchup-side-tag">Away</span> <%= g.away %> <span class="dfs-at">@</span> <span class="matchup-side-tag">Home</span> <%= g.home %>
                <% if (g.location && g.location !== '-') { %>
                <span class="dfs-game-field"><%= g.location %></span>
                <% } %>
              </li>
              <% }) %>
            </ul>
            <% } %>
          </section>

          <section class="dfs-lineup-card dfs-top-panel">
            <h2 class="section-heading dfs-lineup-heading">
              <span class="dfs-lineup-heading-title">Your lineup</span><% if (slate && !slate.canEdit) { %>
              <span class="dfs-lineup-heading-points" id="lineupHeadingScore">Points: <strong data-points-value><% if (typeof showSlateStats !== 'undefined' && showSlateStats && scored && lineupNorms.length) { %><%= scored.total %><% } else { %>—<% } %></strong></span><% } %>
            </h2>
            <p class="dfs-budget">
              <span id="salaryUsedLabel">$<%= salaryUsed.toLocaleString() %></span>
              <span class="dfs-budget-sep">/</span>
              $<%= salaryCap.toLocaleString() %>
              <span class="dfs-budget-remaining" id="salaryRemainingLabel">($<%= salaryRemaining.toLocaleString() %> left)</span>
            </p>
            <ol class="dfs-lineup-slots" id="lineupSlots">
              <% for (let i = 0; i < lineupSize; i++) { %>
              <% const norm = lineupNorms[i]; const p = norm ? playerPool.find((x) => x.norm === norm) : null; %>
              <li class="dfs-lineup-slot<%= p ? ' dfs-lineup-slot--filled' : '' %>" data-slot="<%= i %>">
                <span class="dfs-slot-num"><%= i + 1 %></span>
                <% if (p) { %>
                <span class="dfs-slot-name"><%= p.name %></span>
                <span class="dfs-slot-meta"><%= p.teamName %> · $<%= p.salary.toLocaleString() %></span>
                <button type="button" class="dfs-remove-btn" data-remove="<%= p.norm %>" aria-label="Remove <%= p.name %>">×</button>
                <% } else { %>
                <span class="dfs-slot-empty">Select a player</span>
                <% } %>
              </li>
              <% } %>
            </ol>
            <% if (typeof firebaseEnabled !== 'undefined' && firebaseEnabled && slate && slate.canEdit) { %>
            <section class="dfs-submit-panel" id="dfsSubmitPanel" aria-label="Submit lineup to leaderboard">
              <h3 class="dfs-submit-panel__title">Submit to the leaderboard</h3>
              <p class="dfs-submit-panel__lead">Pick your 8 players above, then enter your name and press Submit.</p>
              <div class="dfs-submit-row">
                <label class="dfs-submit-row__label" for="dfsUsername">Your name</label>
                <input
                  type="text"
                  id="dfsUsername"
                  class="dfs-username-input dfs-submit-row__input"
                  maxlength="24"
                  minlength="2"
                  required
                  autocomplete="nickname"
                  placeholder="Leaderboard name"
                />
                <button type="button" class="dfs-btn dfs-btn--primary dfs-btn--submit" id="saveLineupBtn">
                  Submit lineup
                </button>
              </div>
              <p class="dfs-auth-status dfs-submit-panel__status" id="dfsSubmitStatus" role="status" aria-live="polite"></p>
              <p class="dfs-submit-hint">2–24 characters · shown on the leaderboard · one entry per device per slate</p>
            </section>
            <% } %>
            <p class="dfs-lineup-actions">
              <% if (typeof firebaseEnabled !== 'undefined' && firebaseEnabled) { %>
              <button type="button" class="dfs-btn" id="loadFromDbBtn" disabled title="Load your saved lineup from the database">Load saved lineup</button>
              <% } %>
              <button type="button" class="dfs-btn" id="clearLineupBtn" <%= slate && !slate.canEdit ? 'disabled' : '' %>>Clear lineup</button>
            </p>
            <% if (typeof firebaseEnabled !== 'undefined' && firebaseEnabled) { %>
            <p class="dfs-lineup-sync-status" id="dfsLineupSyncStatus" role="status" aria-live="polite" hidden></p>
            <% } %>
          </section>

          <div class="dfs-side-stack">
            <% const dfsLockDeadlineMs =
              slate && slate.lineupLockDeadlineMs != null ? slate.lineupLockDeadlineMs : null;
            const dfsLockDeadlineLabel =
              slate && slate.lineupLockDeadlineLabel ? slate.lineupLockDeadlineLabel : ''; %>
            <section class="dfs-lock-panel dfs-top-panel" aria-label="Lineup deadline">
              <h2 class="section-heading dfs-lock-panel__title">Lineup deadline</h2>
              <div
                class="dfs-lock-countdown"
                id="dfsLockCountdown"
                <% if (dfsLockDeadlineMs != null) { %>data-deadline-ms="<%= dfsLockDeadlineMs %>"<% } %>
                aria-live="polite"
                <%= dfsLockDeadlineMs == null ? 'hidden' : '' %>
              >
                <p class="dfs-lock-countdown__label">Lineups lock in (New York time)</p>
                <p class="dfs-lock-countdown__timer" id="dfsLockCountdownTimer">—</p>
                <% if (dfsLockDeadlineLabel) { %>
                <p class="dfs-lock-countdown__when" id="dfsLockCountdownWhen"><%= dfsLockDeadlineLabel %></p>
                <% if (slate && slate.slateType === 'wednesday') { %>
                <p class="dfs-lock-countdown__rule">Wednesday slates lock at <strong>8:00 PM Eastern</strong> on game day.</p>
                <% } else if (slate && slate.canEdit) { %>
                <p class="dfs-lock-countdown__rule">Week slates lock at <strong>11:59 PM Eastern</strong> the night before games.</p>
                <% } %>
                <% } else { %>
                <p class="dfs-lock-countdown__when" id="dfsLockCountdownWhen" hidden></p>
                <% } %>
              </div>
              <p
                class="dfs-lock-countdown dfs-lock-countdown--closed"
                id="dfsLockCountdownClosed"
                <%= dfsLockDeadlineMs != null ? 'hidden' : '' %>
              >
                Lineups are locked — no upcoming slate deadline.
              </p>
            </section>

            <section class="dfs-scoring-rules dfs-top-panel" aria-label="Scoring rules">
            <h2 class="section-heading">Scoring (per game)</h2>
            <ul class="dfs-rules-list">
              <li>Single <strong>+<%= scoringRules.single %></strong></li>
              <li>Double <strong>+<%= scoringRules.double %></strong></li>
              <li>Triple <strong>+<%= scoringRules.triple %></strong></li>
              <li>Home run <strong>+<%= scoringRules.hr %></strong></li>
              <li>RBI <strong>+<%= scoringRules.rbi %></strong></li>
              <li>Run <strong>+<%= scoringRules.run %></strong></li>
              <li>Walk <strong>+<%= scoringRules.walk %></strong></li>
            </ul>
            <% if (!hasGamelogData) { %>
            <p class="dfs-rules-note">Point totals aren’t available yet — check back after games are played.</p>
            <% } %>
            </section>
          </div>
        </div>

        <div class="dfs-extra-panels">
          <% if (typeof lastWeekPreview !== 'undefined' && lastWeekPreview) { %>
          <section
            class="dfs-last-week-card"
            id="lastWeekPreviewCard"
            hidden
            aria-live="polite"
            data-has-stats="<%= lastWeekPreview.hasStats ? '1' : '0' %>"
          >
            <h2 class="section-heading">If this was your lineup last week</h2>
            <p class="dfs-last-week-slate"><%= lastWeekPreview.slateLabel %></p>
            <% if (!lastWeekPreview.hasStats) { %>
            <p class="dfs-last-week-empty">No scoring data for that week yet.</p>
            <% } else { %>
            <p class="dfs-last-week-total">
              <span id="lastWeekTotal"><%= lastWeekPreview.scored ? lastWeekPreview.scored.total : 0 %></span>
              <span class="dfs-score-pts">pts</span>
            </p>
            <ul class="dfs-last-week-breakdown" id="lastWeekBreakdown">
              <% if (lastWeekPreview.scored) { %>
              <% lastWeekPreview.scored.breakdown.forEach((row) => { %>
              <li>
                <span><%= row.name %></span>
                <strong><%= row.points %></strong>
                <span class="dfs-score-games"><%= row.games %> gm</span>
              </li>
              <% }) %>
              <% } %>
            </ul>
            <% } %>
          </section>
          <script type="application/json" id="lastWeekPointsData"><%- JSON.stringify(lastWeekPreview.byNorm) %></script>
          <% } %>

          <% if (typeof showSlateStats !== 'undefined' && showSlateStats) { %>
          <section class="dfs-score-card" id="slateScoreCard">
            <h2 class="section-heading">Your lineup score</h2>
            <% if (!slateStats || !slateStats.hasStats) { %>
            <% if (typeof slateHasBoxScores !== 'undefined' && !slateHasBoxScores) { %>
            <p class="dfs-rules-note">Game results aren’t available for this slate’s scheduled dates yet — fantasy points will show here once they are.</p>
            <% } else { %>
            <p class="dfs-rules-note">No scoring results for this slate yet.</p>
            <% } %>
            <% } %>
            <p class="dfs-score-total">
              <span id="slateScoreTotal"><%= scored ? scored.total : '—' %></span>
              <span class="dfs-score-pts">pts</span>
            </p>
            <ul class="dfs-score-breakdown" id="slateScoreBreakdown">
              <% if (scored && scored.breakdown) { %>
              <% scored.breakdown.forEach((row) => { %>
              <li>
                <span><%= row.name %></span>
                <strong><%= row.points %></strong>
                <span class="dfs-score-games"><%= row.games %> gm<% if (row.games > 1) { %> avg<% } %></span>
              </li>
              <% }) %>
              <% } %>
            </ul>
          </section>
          <% if (slateStats && slateStats.byNorm) { %>
          <script type="application/json" id="slatePointsData"><%- JSON.stringify(slateStats.byNorm) %></script>
          <% } %>
          <% } %>
        </div>

        <% if (!canEdit) { %>
        <p class="dfs-pool-hidden-notice" role="status">
          The player pool is hidden after the lineup deadline. Your saved lineup and locked salaries are shown above; the leaderboard uses those same prices.
        </p>
        <% } %>
        <section class="dfs-pool-section" id="dfsPoolSection" <%= canEdit ? '' : 'hidden' %>>
          <div class="dfs-pool-toolbar">
            <h2 class="section-heading">Player pool</h2>
            <p class="dfs-doubleheader-note" role="note">
              <span class="dfs-doubleheader-badge" aria-hidden="true">2G</span>
              Doubleheader — two games this slate. Points are the average of both games, rounded to a whole number. Salary includes a modest boost for extra plate appearances.
            </p>
            <div class="dfs-pool-toolbar-actions">
              <div class="dfs-sort-group" role="group" aria-label="Sort player pool">
                <span class="dfs-sort-label">Sort</span>
                <button type="button" class="dfs-sort-btn<%= (typeof showSlateStats !== 'undefined' && showSlateStats) ? '' : ' is-active' %>" data-sort="salary">Salary</button>
                <button type="button" class="dfs-sort-btn" data-sort="team">Team</button>
                <% if (typeof showSlateStats !== 'undefined' && showSlateStats) { %>
                <button type="button" class="dfs-sort-btn is-active" data-sort="points">Points</button>
                <% } %>
              </div>
              <label class="dfs-team-filter" id="teamFilterWrap" hidden>
                <span class="dfs-team-filter-label">Team</span>
                <select id="teamFilter" aria-label="Filter by team">
                  <option value="">All teams</option>
                </select>
              </label>
              <label class="dfs-search-label">
                Search
                <input type="search" id="poolSearch" placeholder="Name, team, or field…" autocomplete="off" />
              </label>
            </div>
          </div>
          <div class="dfs-table-wrap">
            <table class="dfs-player-table page-table" id="playerPoolTable">
              <thead>
                <tr>
                  <% if (!(typeof showSlateStats !== 'undefined' && showSlateStats)) { %><th></th><% } %>
                  <th>Player</th>
                  <th>Team</th>
                  <th>Field</th>
                  <th>Salary</th>
                  <% if (typeof showSlateStats !== 'undefined' && showSlateStats) { %>
                  <th>Pts</th>
                  <th>Gm</th>
                  <% } %>
                  <th>vs</th>
                  <th>Opposing Pitcher</th>
                </tr>
              </thead>
              <tbody>
                <% if (typeof clientSidePool !== 'undefined' && clientSidePool) { %>
                <tr>
                  <td colspan="<%= (typeof showSlateStats !== 'undefined' && showSlateStats) ? 7 : 8 %>" class="dfs-leaderboard-empty">
                    Loading player pool and salaries from Google Sheets…
                  </td>
                </tr>
                <% } else { playerPool.forEach((p) => { %>
                <% const inLineup = lineupNorms.includes(p.norm); %>
                <tr
                  class="dfs-player-row<%= inLineup ? ' dfs-player-row--selected' : '' %>"
                  data-norm="<%= p.norm %>"
                  data-name="<%= p.name %>"
                  data-team="<%= p.teamName %>"
                  data-salary="<%= p.salary %>"
                  data-field="<%- String(p.gameField != null ? p.gameField : '—').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/\n/g, ' ') %>"
                  data-points="<%= p.slatePoints != null ? p.slatePoints : 0 %>"
                  data-games="<%= p.slateGames != null ? p.slateGames : 0 %>"
                >
                  <% if (!(typeof showSlateStats !== 'undefined' && showSlateStats)) { %>
                  <td>
                    <button
                      type="button"
                      class="dfs-add-btn<%= inLineup ? ' dfs-add-btn--remove' : '' %>"
                      data-toggle="<%= p.norm %>"
                      aria-pressed="<%= inLineup ? 'true' : 'false' %>"
                    ><%= inLineup ? '−' : '+' %></button>
                  </td>
                  <% } %>
                  <td class="dfs-player-name">
                    <%= p.name %><% if (p.doubleHeader) { %><span class="dfs-doubleheader-tag" title="Two games this slate">2G</span><% } %>
                  </td>
                  <td><%= p.teamName %></td>
                  <td class="dfs-field-cell dfs-cell-preline" title="Diamond / short-field from schedule (Field, Short Field)"><%= p.gameField || "—" %></td>
                  <td class="dfs-salary-cell">$<%= p.salary.toLocaleString() %></td>
                  <% if (typeof showSlateStats !== 'undefined' && showSlateStats) { %>
                  <td class="dfs-points-cell"><strong><%= p.slatePoints %></strong></td>
                  <td class="dfs-games-cell"><%= p.slateGames %></td>
                  <% } %>
                  <td class="dfs-opp-cell dfs-cell-preline"><%= p.opponentName %></td>
                  <td class="dfs-pitcher-cell dfs-cell-preline" title="<%= p.pitcherBaa != null ? 'BAA ' + p.pitcherBaa + ', Runs/G ' + p.pitcherRunsG : '' %>"><%= p.opposingPitcher %></td>
                </tr>
                <% }); } %>
              </tbody>
            </table>
          </div>
          <% if (!(typeof clientSidePool !== 'undefined' && clientSidePool) && !playerPool.length) { %>
          <p class="dfs-empty-pool">No players in pool for this slate. Pick another date/week above.</p>
          <% } %>
        </section>
      </div>
    </main>

    <% if (typeof firebaseEnabled !== 'undefined' && firebaseEnabled && firebaseClientConfig) { %>
    <script>
      window.__FIREBASE_CONFIG__ = <%- JSON.stringify(firebaseClientConfig) %>;
    </script>
    <script type="module" src="<%= sitePath('/js/dfs-firebase.js') %>?v=<%= assetVersion %>"></script>
    <% } %>

    <% if (typeof clientSidePool !== 'undefined' && clientSidePool) { %>
    <script>
      window.__MMS_CAREER_CSV_URL__ = "<%= sitePath('/data/csv/career.csv') %>";
      window.__DFS_LINEUP_PAGE__ = <%- JSON.stringify({
        slateToken: selectedSlate,
        lineupNorms: lineupNorms || [],
        showSlateStats: typeof showSlateStats !== 'undefined' && showSlateStats
      }) %>;
    </script>
    <script type="module" src="<%= sitePath('/js/dfs-lineup-pool.js') %>?v=<%= assetVersion %>"></script>
    <% } %>

    <script type="module">
      import {
        setupLineupLockCountdown,
        navigateToOpenDfsSlate,
      } from "<%= sitePath('/js/dfs-lock-countdown.js') %>?v=<%= assetVersion %>";

      const initialDeadline =
        <%= typeof dfsLockDeadlineMs !== 'undefined' && dfsLockDeadlineMs != null ? dfsLockDeadlineMs : 'null' %>;

      setupLineupLockCountdown({
        deadlineMs: initialDeadline,
        onLocked: () => navigateToOpenDfsSlate(null),
      });
    </script>

    <script>
      window.initDfsLineupPage = function () {
        const LINEUP_SIZE = <%= lineupSize %>;
        const SALARY_CAP = <%= salaryCap %>;
        var CAN_EDIT = <%= slate && slate.canEdit ? 'true' : 'false' %>;
        window.setDfsCanEdit = function (editable) {
          CAN_EDIT = !!editable;
          const page = document.querySelector(".dfs-page");
          if (page) page.classList.toggle("dfs-page--readonly", !CAN_EDIT);
          const poolSection = document.getElementById("dfsPoolSection");
          if (poolSection) poolSection.hidden = !CAN_EDIT;
          const submitPanel = document.getElementById("dfsSubmitPanel");
          if (submitPanel) submitPanel.hidden = !CAN_EDIT;
          const clearBtn = document.getElementById("clearLineupBtn");
          if (clearBtn) clearBtn.disabled = !CAN_EDIT;
        };
        const SHOW_SLATE_STATS = <%= typeof showSlateStats !== 'undefined' && showSlateStats ? 'true' : 'false' %>;
        const STORAGE_PREFIX = "mms-dfs-lineup:";
        const slateKey = "<%= selectedSlate %>";
        const form = document.getElementById("dfsSlateForm");
        const lineupInput = document.getElementById("lineupInput");
        const pool = new Map();
        document.querySelectorAll(".dfs-player-row").forEach((row) => {
          pool.set(row.getAttribute("data-norm"), {
            norm: row.getAttribute("data-norm"),
            name: row.getAttribute("data-name"),
            team: row.getAttribute("data-team"),
            field: row.getAttribute("data-field") || "",
            salary: Number(row.getAttribute("data-salary")),
          });
        });


        (function setupDfsIntroInfo() {
          const btn = document.getElementById("dfsIntroBtn");
          const panel = document.getElementById("dfsIntroPanel");
          const closeBtn = document.getElementById("dfsIntroClose");
          if (!btn || !panel) return;

          function setOpen(open) {
            panel.hidden = !open;
            btn.setAttribute("aria-expanded", open ? "true" : "false");
          }

          function toggle() {
            setOpen(panel.hidden);
          }

          btn.addEventListener("click", (e) => {
            e.stopPropagation();
            toggle();
          });

          closeBtn?.addEventListener("click", () => setOpen(false));

          document.addEventListener("click", (e) => {
            if (panel.hidden) return;
            if (e.target.closest(".dfs-info-wrap")) return;
            setOpen(false);
          });

          document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !panel.hidden) setOpen(false);
          });
        })();

        (function setupLineupNotices() {
          const row = document.getElementById("dfsLineupNotices");
          if (!row) return;

          const storagePrefix = "mms-dfs-notice-dismiss-";

          function syncNoticesLayout() {
            const visible = row.querySelectorAll(".dfs-lineup-notice:not([hidden])");
            row.classList.toggle("dfs-lineup-notices--single", visible.length === 1);
            row.hidden = visible.length === 0;
          }

          row.querySelectorAll(".dfs-lineup-notice").forEach((notice) => {
            const key = notice.id;
            if (key && sessionStorage.getItem(storagePrefix + key)) {
              notice.hidden = true;
            }
            const dismiss = notice.querySelector(".dfs-notice-dismiss");
            dismiss?.addEventListener("click", () => {
              notice.hidden = true;
              if (key) sessionStorage.setItem(storagePrefix + key, "1");
              syncNoticesLayout();
            });
          });

          syncNoticesLayout();
        })();

        (function setupPlayerBar() {
          const input = document.getElementById("dfsUsername");
          if (!input) return;
          const saved = (localStorage.getItem("mms-dfs-username") || "").trim();
          if (saved) input.value = saved;
          input.addEventListener("change", () => {
            window.DfsLineupStore?.setUsername?.(input.value);
          });
          input.addEventListener("input", () => {
            window.DfsLineupStore?.setUsername?.(input.value);
          });
        })();

        let lineup = lineupInput.value
          .split(",")
          .map((s) => s.trim())
          .filter((n) => pool.has(n));

        /** Salaries locked when a player is added (or loaded from a saved lineup). */
        const lockedSalaries = new Map();

        function playerSalary(norm) {
          if (lockedSalaries.has(norm)) return lockedSalaries.get(norm);
          return pool.get(norm)?.salary || 0;
        }

        function buildPlayerSalariesArray() {
          return lineup.map((n) => playerSalary(n));
        }

        function applyLockedSalaries(norms, salaries) {
          lockedSalaries.clear();
          if (!Array.isArray(norms) || !Array.isArray(salaries)) return;
          const len = Math.min(norms.length, salaries.length);
          for (let i = 0; i < len; i += 1) {
            const norm = norms[i];
            const sal = Number(salaries[i]);
            if (pool.has(norm) && Number.isFinite(sal) && sal > 0) {
              lockedSalaries.set(norm, sal);
            }
          }
        }

        function loadStored() {
          if (!slateKey) return null;
          try {
            const raw = localStorage.getItem(STORAGE_PREFIX + slateKey);
            if (!raw) return null;
            const data = JSON.parse(raw);
            const norms = Array.isArray(data.lineup)
              ? data.lineup.filter((n) => pool.has(n))
              : null;
            if (norms && Array.isArray(data.playerSalaries)) {
              applyLockedSalaries(norms, data.playerSalaries);
            }
            return norms;
          } catch {
            return null;
          }
        }

        function saveStored() {
          if (!slateKey || !CAN_EDIT) return;
          localStorage.setItem(
            STORAGE_PREFIX + slateKey,
            JSON.stringify({
              lineup: [...lineup],
              playerSalaries: buildPlayerSalariesArray(),
              updatedAt: Date.now(),
            })
          );
        }

        function persistLineup() {
          saveStored();
          lineupInput.value = lineup.join(",");
        }

        async function saveLineupToCloud() {
          if (!CAN_EDIT) {
            throw new Error("Lineups can only be edited for the slate that is currently open.");
          }
          if (!/^W\d+$/i.test(slateKey) && !/^D\d{8}$/i.test(slateKey)) {
            throw new Error("Cloud save is only for Sunday week slates (W1, W2, …) and Wednesday slates (D + date).");
          }
          if (!window.DfsLineupStore) {
            throw new Error("Lineup storage is still loading — wait a moment and try again.");
          }
          const usernameInput = document.getElementById("dfsUsername");
          const displayName = usernameInput ? usernameInput.value : "";
          window.DfsLineupStore.validateUsername(displayName);
          if (lineup.length !== LINEUP_SIZE) {
            throw new Error("Pick exactly " + LINEUP_SIZE + " players before saving.");
          }
          if (salaryTotal() > SALARY_CAP) {
            throw new Error("Your lineup is over the salary cap.");
          }
          const playerSalaries = buildPlayerSalariesArray();
          const used = playerSalaries.reduce((s, n) => s + n, 0);
          await window.DfsLineupStore.saveLineup(slateKey, lineup, used, playerSalaries, displayName);
        }

        function salaryTotal() {
          return lineup.reduce((s, n) => s + playerSalary(n), 0);
        }

        let lastWeekByNorm = null;
        try {
          const el = document.getElementById("lastWeekPointsData");
          if (el) lastWeekByNorm = JSON.parse(el.textContent || "{}");
        } catch {
          lastWeekByNorm = null;
        }

        let slatePointsByNorm = null;
        try {
          const el = document.getElementById("slatePointsData");
          if (el) slatePointsByNorm = JSON.parse(el.textContent || "{}");
        } catch {
          slatePointsByNorm = null;
        }

        function computeLineupPointsTotal() {
          if (!slatePointsByNorm || !lineup.length) return null;
          let total = 0;
          for (const norm of lineup) {
            total += (slatePointsByNorm[norm] || { points: 0 }).points;
          }
          return Math.round(total);
        }

        function updateLineupHeadingScore(total) {
          const wrap = document.getElementById("lineupHeadingScore");
          if (!wrap || CAN_EDIT) return;
          const valEl = wrap.querySelector("[data-points-value]");
          if (!valEl) return;
          if (!lineup.length) {
            valEl.textContent = "—";
            return;
          }
          if (!SHOW_SLATE_STATS || !slatePointsByNorm) {
            valEl.textContent = "—";
            return;
          }
          const t = total != null ? total : computeLineupPointsTotal();
          valEl.textContent = t == null ? "—" : String(t);
        }

        function updateSlateScoreCard() {
          const card = document.getElementById("slateScoreCard");
          if (!card || !slatePointsByNorm) {
            updateLineupHeadingScore(null);
            return;
          }

          const totalEl = document.getElementById("slateScoreTotal");
          const list = document.getElementById("slateScoreBreakdown");

          if (!lineup.length) {
            if (totalEl) totalEl.textContent = "—";
            if (list) list.innerHTML = "";
            updateLineupHeadingScore(null);
            return;
          }

          let total = 0;
          if (list) list.innerHTML = "";
          for (const norm of lineup) {
            const row = slatePointsByNorm[norm] || { points: 0, games: 0 };
            const p = pool.get(norm);
            total += row.points;
            if (list) {
              const li = document.createElement("li");
              li.innerHTML =
                "<span>" +
                (p ? p.name : norm) +
                "</span><strong>" +
                row.points +
                '</strong><span class="dfs-score-games">' +
                row.games +
                " gm" +
                (row.games > 1 ? " avg" : "") +
                "</span>";
              list.appendChild(li);
            }
          }
          const rounded = Math.round(total);
          if (totalEl) totalEl.textContent = String(rounded);
          updateLineupHeadingScore(rounded);
        }

        function updateLastWeekPreview() {
          const card = document.getElementById("lastWeekPreviewCard");
          if (!card || !lastWeekByNorm) return;

          if (!lineup.length) {
            card.hidden = true;
            return;
          }
          card.hidden = false;

          if (card.getAttribute("data-has-stats") !== "1") return;

          let total = 0;
          const list = document.getElementById("lastWeekBreakdown");
          const totalEl = document.getElementById("lastWeekTotal");
          if (!list || !totalEl) return;

          list.innerHTML = "";
          for (const norm of lineup) {
            const row = lastWeekByNorm[norm] || { points: 0, games: 0 };
            const p = pool.get(norm);
            total += row.points;
            const li = document.createElement("li");
            li.innerHTML =
              "<span>" +
              (p ? p.name : norm) +
              "</span><strong>" +
              row.points +
              '</strong><span class="dfs-score-games">' +
              row.games +
              " gm</span>";
            list.appendChild(li);
          }
          totalEl.textContent = String(Math.round(total));
        }

        function syncUi() {
          const used = salaryTotal();
          const left = SALARY_CAP - used;
          document.getElementById("salaryUsedLabel").textContent = "$" + used.toLocaleString();
          const rem = document.getElementById("salaryRemainingLabel");
          rem.textContent = "($" + left.toLocaleString() + " left)";
          rem.classList.toggle("dfs-budget-over", left < 0);

          document.querySelectorAll(".dfs-player-row").forEach((row) => {
            const norm = row.getAttribute("data-norm");
            const on = lineup.includes(norm);
            const addSalary = Number(row.getAttribute("data-salary")) || 0;
            const overCap = !on && used + addSalary > SALARY_CAP;
            row.classList.toggle("dfs-player-row--selected", on);
            row.classList.toggle("dfs-player-row--over-cap", overCap);
            const btn = row.querySelector(".dfs-add-btn");
            if (btn) {
              btn.textContent = on ? "−" : "+";
              btn.classList.toggle("dfs-add-btn--remove", on);
              btn.setAttribute("aria-pressed", on ? "true" : "false");
              btn.disabled = overCap;
              btn.title = overCap ? "Not enough salary cap remaining" : "";
            }
          });

          const slots = document.getElementById("lineupSlots");
          slots.innerHTML = "";
          for (let i = 0; i < LINEUP_SIZE; i++) {
            const norm = lineup[i];
            const p = norm ? pool.get(norm) : null;
            const li = document.createElement("li");
            li.className = "dfs-lineup-slot" + (p ? " dfs-lineup-slot--filled" : "");
            li.innerHTML =
              '<span class="dfs-slot-num">' +
              (i + 1) +
              "</span>" +
              (p
                ? (function () {
                    const pts = slatePointsByNorm && slatePointsByNorm[norm];
                    const ptsLabel =
                      pts && SHOW_SLATE_STATS ? " · " + pts.points + " pts" : "";
                    const slotSalary = playerSalary(norm);
                    const locked = lockedSalaries.has(norm);
                    const meta =
                      p.team +
                      " · $" +
                      slotSalary.toLocaleString() +
                      (locked ? " (locked at save)" : "") +
                      ptsLabel;
                    const removeBtn = CAN_EDIT
                      ? '<button type="button" class="dfs-remove-btn" data-remove="' +
                        p.norm +
                        '" aria-label="Remove">×</button>'
                      : "";
                    return (
                      '<span class="dfs-slot-name">' +
                      p.name +
                      '</span><span class="dfs-slot-meta">' +
                      meta +
                      "</span>" +
                      removeBtn
                    );
                  })()
                : '<span class="dfs-slot-empty">' +
                  (CAN_EDIT ? "Select a player" : "No saved lineup") +
                  "</span>");
            slots.appendChild(li);
          }

          slots.querySelectorAll("[data-remove]").forEach((btn) => {
            btn.addEventListener("click", () => togglePlayer(btn.getAttribute("data-remove")));
          });

          updateLastWeekPreview();
          updateSlateScoreCard();
          if (!CAN_EDIT) updateLineupHeadingScore(null);
        }

        function togglePlayer(norm) {
          if (!CAN_EDIT) return;
          const ix = lineup.indexOf(norm);
          if (ix >= 0) {
            lineup.splice(ix, 1);
            lockedSalaries.delete(norm);
          } else {
            if (lineup.length >= LINEUP_SIZE) {
              alert("Lineup is full (" + LINEUP_SIZE + " players). Remove someone first.");
              return;
            }
            const addSalary = pool.get(norm)?.salary || 0;
            const nextTotal = salaryTotal() + addSalary;
            if (nextTotal > SALARY_CAP) {
              alert("Not enough salary cap remaining for this player.");
              return;
            }
            lockedSalaries.set(norm, addSalary);
            lineup.push(norm);
          }
          persistLineup();
          syncUi();
        }

        document.querySelectorAll("[data-toggle]").forEach((btn) => {
          btn.addEventListener("click", () => togglePlayer(btn.getAttribute("data-toggle")));
        });

        document.getElementById("clearLineupBtn").addEventListener("click", () => {
          if (!CAN_EDIT) return;
          lineup = [];
          lockedSalaries.clear();
          persistLineup();
          syncUi();
        });

        if (!CAN_EDIT) {
          document.querySelectorAll(".dfs-add-btn").forEach((btn) => {
            btn.disabled = true;
          });
        }

        const loadFromDbBtn = document.getElementById("loadFromDbBtn");
        if (loadFromDbBtn) {
          loadFromDbBtn.addEventListener("click", async () => {
            const btn = loadFromDbBtn;
            try {
              btn.disabled = true;
              const prevLabel = btn.textContent;
              btn.textContent = "Loading…";
              await pullLineupFromDatabase();
              btn.textContent = prevLabel;
            } catch (err) {
              console.error(err);
              setLineupSyncStatus(err.message || "Could not load lineup from the database.", true);
            } finally {
              updateLoadFromDbButton();
            }
          });
        }

        document.getElementById("saveLineupBtn").addEventListener("click", async () => {
          const btn = document.getElementById("saveLineupBtn");
          const status = document.getElementById("dfsSubmitStatus");
          try {
            persistLineup();
            btn.disabled = true;
            const prevLabel = btn.textContent;
            btn.textContent = "Saving…";
            const hadSaved = await window.DfsLineupStore.hasLineupForSlate(slateKey);
            await saveLineupToCloud();
            setLineupSyncStatus(
              hadSaved
                ? "Lineup updated for " + slateKey.toUpperCase() + ". You can keep editing until the deadline."
                : "Lineup saved for " + slateKey.toUpperCase() + ". You can change it anytime before the deadline.",
              false
            );
            if (status) {
              status.textContent =
                "Saved as " + (window.DfsLineupStore?.getUsername?.() || "Player") + " for " + slateKey.toUpperCase() + ".";
            }
            await updateSaveButtonState();
          } catch (err) {
            console.error(err);
            btn.disabled = false;
            await updateSaveButtonState();
            alert(err.message || "Could not save lineup. Try again.");
          }
        });

        const tbody = document.querySelector("#playerPoolTable tbody");
        const teamFilterWrap = document.getElementById("teamFilterWrap");
        const teamFilter = document.getElementById("teamFilter");
        let currentSort = "salary";

        function buildTeamRank() {
          const maxByTeam = new Map();
          document.querySelectorAll(".dfs-player-row").forEach((row) => {
            const team = row.getAttribute("data-team");
            const sal = Number(row.getAttribute("data-salary"));
            maxByTeam.set(team, Math.max(maxByTeam.get(team) || 0, sal));
          });
          const teams = [...maxByTeam.entries()]
            .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], undefined, { sensitivity: "base" }))
            .map(([name]) => name);
          const rank = new Map(teams.map((name, i) => [name, i]));
          return { teams, rank };
        }

        function refreshTeamFilterOptions() {
          if (!teamFilter) return;
          const { teams } = buildTeamRank();
          const kept = teamFilter.value;
          teamFilter.innerHTML = '<option value="">All teams</option>';
          teams.forEach((name) => {
            const opt = document.createElement("option");
            opt.value = name;
            opt.textContent = name;
            teamFilter.appendChild(opt);
          });
          if (kept && teams.includes(kept)) teamFilter.value = kept;
        }

        function applyPoolFilters() {
          const q = (document.getElementById("poolSearch")?.value || "").trim().toLowerCase();
          const teamVal = currentSort === "team" && teamFilter ? teamFilter.value : "";
          document.querySelectorAll(".dfs-player-row").forEach((row) => {
            const hay = (
              row.getAttribute("data-name") +
              " " +
              row.getAttribute("data-team") +
              " " +
              (row.getAttribute("data-field") || "")
            ).toLowerCase();
            const matchesSearch = !q || hay.includes(q);
            const matchesTeam = !teamVal || row.getAttribute("data-team") === teamVal;
            row.hidden = !matchesSearch || !matchesTeam;
          });
        }

        function sortPlayerPool(mode) {
          if (!tbody) return;
          const rows = Array.from(tbody.querySelectorAll(".dfs-player-row"));
          if (mode === "team") {
            const { rank } = buildTeamRank();
            rows.sort((a, b) => {
              const ta = a.getAttribute("data-team");
              const tb = b.getAttribute("data-team");
              const ra = rank.get(ta) ?? 999;
              const rb = rank.get(tb) ?? 999;
              if (ra !== rb) return ra - rb;
              const sa = Number(a.getAttribute("data-salary"));
              const sb = Number(b.getAttribute("data-salary"));
              if (sb !== sa) return sb - sa;
              return a.getAttribute("data-name").localeCompare(b.getAttribute("data-name"), undefined, {
                sensitivity: "base",
              });
            });
          } else if (mode === "points") {
            rows.sort((a, b) => {
              const pa = Number(a.getAttribute("data-points")) || 0;
              const pb = Number(b.getAttribute("data-points")) || 0;
              if (pb !== pa) return pb - pa;
              return a.getAttribute("data-name").localeCompare(b.getAttribute("data-name"), undefined, {
                sensitivity: "base",
              });
            });
          } else {
            rows.sort((a, b) => {
              const sa = Number(a.getAttribute("data-salary"));
              const sb = Number(b.getAttribute("data-salary"));
              if (sb !== sa) return sb - sa;
              return a.getAttribute("data-name").localeCompare(b.getAttribute("data-name"), undefined, {
                sensitivity: "base",
              });
            });
          }
          rows.forEach((row) => tbody.appendChild(row));
          applyPoolFilters();
        }

        function setSortMode(mode) {
          currentSort = mode;
          if (teamFilterWrap) {
            const showTeam = mode === "team";
            teamFilterWrap.hidden = !showTeam;
            teamFilterWrap.setAttribute("aria-hidden", showTeam ? "false" : "true");
          }
          if (mode === "team") {
            refreshTeamFilterOptions();
          } else if (teamFilter) {
            teamFilter.value = "";
          }
          sortPlayerPool(mode);
        }

        document.querySelectorAll(".dfs-sort-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            document.querySelectorAll(".dfs-sort-btn").forEach((b) => b.classList.remove("is-active"));
            btn.classList.add("is-active");
            setSortMode(btn.getAttribute("data-sort"));
          });
        });

        if (teamFilter) {
          teamFilter.addEventListener("change", applyPoolFilters);
        }

        const search = document.getElementById("poolSearch");
        if (search) {
          search.addEventListener("input", applyPoolFilters);
        }

        function applyLineupFromArray(norms, salaries) {
          lineup = (norms || []).filter((n) => pool.has(n)).slice(0, LINEUP_SIZE);
          if (salaries) {
            applyLockedSalaries(lineup, salaries);
          } else {
            lockedSalaries.clear();
            lineup.forEach((n) => {
              const sal = pool.get(n)?.salary;
              if (sal != null) lockedSalaries.set(n, sal);
            });
          }
          persistLineup();
          syncUi();
        }

        function isCloudSlateKey(key) {
          return /^W\d+$/i.test(key || "") || /^D\d{8}$/i.test(key || "");
        }

        function normalizeLineupNorms(norms) {
          return (norms || []).filter((n) => pool.has(n)).slice(0, LINEUP_SIZE);
        }

        function lineupsMatch(a, b) {
          const na = normalizeLineupNorms(a);
          const nb = normalizeLineupNorms(b);
          if (na.length !== nb.length) return false;
          for (let i = 0; i < na.length; i += 1) {
            if (na[i] !== nb[i]) return false;
          }
          return true;
        }

        function setLineupSyncStatus(message, isWarning) {
          const el = document.getElementById("dfsLineupSyncStatus");
          if (!el) return;
          if (!message) {
            el.hidden = true;
            el.textContent = "";
            el.className = "dfs-lineup-sync-status";
            return;
          }
          el.hidden = false;
          el.className =
            "dfs-lineup-sync-status" + (isWarning ? " dfs-lineup-sync-status--warn" : "");
          el.textContent = message;
        }

        function updateLoadFromDbButton() {
          const btn = document.getElementById("loadFromDbBtn");
          if (!btn) return;
          const canLoad = !!window.DfsLineupStore && isCloudSlateKey(slateKey);
          btn.disabled = !canLoad;
          if (canLoad) {
            btn.title = "Load your submitted lineup for this slate";
          } else {
            btn.title = "This slate does not sync to the database";
          }
        }

        async function updateSaveButtonState() {
          const btn = document.getElementById("saveLineupBtn");
          const status = document.getElementById("dfsSubmitStatus");
          if (!btn || !window.DfsLineupStore) return;
          if (!isCloudSlateKey(slateKey)) {
            btn.textContent = "Submit lineup";
            return;
          }
          if (!CAN_EDIT) {
            return;
          }
          try {
            const submitted = await window.DfsLineupStore.hasLineupForSlate(slateKey);
            btn.disabled = false;
            btn.textContent = submitted ? "Update lineup" : "Submit lineup";
            if (status && submitted) {
              status.textContent =
                "You have a saved lineup for " +
                slateKey.toUpperCase() +
                " — change players and save again before the deadline.";
            }
          } catch (e) {
            console.warn("Save button state", e);
          }
        }

        async function autoLoadLockedLineupForView() {
          if (CAN_EDIT || !isCloudSlateKey(slateKey)) return;
          if (!window.DfsLineupStore) return;
          try {
            await pullLineupFromDatabase(true);
          } catch (e) {
            console.warn("Auto-load lineup", e);
          }
        }

        async function pullLineupFromDatabase(silent) {
          if (!window.DfsLineupStore) {
            throw new Error("Lineup storage is still loading — wait a moment and try again.");
          }
          if (!isCloudSlateKey(slateKey)) {
            throw new Error("This slate cannot sync to the database.");
          }
          const cloudRaw = await window.DfsLineupStore.loadLineup(slateKey);
          const cloudNorms = normalizeLineupNorms(
            cloudRaw?.playerNorms || (Array.isArray(cloudRaw) ? cloudRaw : [])
          );
          const cloudSalaries = cloudRaw?.playerSalaries || null;
          if (!cloudNorms.length) {
            if (!silent) {
              setLineupSyncStatus(
                "No lineup saved in the database for " + slateKey.toUpperCase() + " yet.",
                false
              );
            }
            return;
          }
          const localNorms = normalizeLineupNorms(loadStored() || lineup);
          const differs = !lineupsMatch(localNorms, cloudNorms);
          if (!silent) {
            if (differs) {
              setLineupSyncStatus(
                "Your lineup on this device differs from your saved database lineup. The database version is now loaded.",
                true
              );
            } else {
              setLineupSyncStatus(
                "Your lineup on this device matches the database. Loaded your saved lineup.",
                false
              );
            }
          }
          applyLineupFromArray(cloudNorms, cloudSalaries);
        }

        async function loadSavedLineupForOpenSlate() {
          if (!CAN_EDIT || !isCloudSlateKey(slateKey) || !window.DfsLineupStore) return;
          try {
            const cloudRaw = await window.DfsLineupStore.loadLineup(slateKey);
            const cloudNorms = normalizeLineupNorms(cloudRaw?.playerNorms || []);
            if (!cloudNorms.length) return;
            applyLineupFromArray(cloudNorms, cloudRaw?.playerSalaries || null);
            const un = document.getElementById("dfsUsername");
            if (un && cloudRaw.displayName) {
              un.value = cloudRaw.displayName;
              window.DfsLineupStore.setUsername(cloudRaw.displayName);
            }
            setLineupSyncStatus(
              "Loaded your saved lineup — update it anytime before the deadline.",
              false
            );
          } catch (e) {
            console.warn("Load saved lineup", e);
          }
        }

        async function setupLineupStore() {
          updateLoadFromDbButton();
          if (!CAN_EDIT && isCloudSlateKey(slateKey)) {
            await autoLoadLockedLineupForView();
          } else {
            await loadSavedLineupForOpenSlate();
          }
          await updateSaveButtonState();
        }

        function initLineupFromStorage() {
          if (!CAN_EDIT && isCloudSlateKey(slateKey)) return;
          const stored = loadStored();
          if (stored && stored.length) {
            lineup = stored.slice(0, LINEUP_SIZE);
          }
          persistLineup();
          syncUi();
        }

        initLineupFromStorage();
        setSortMode(SHOW_SLATE_STATS ? "points" : "salary");

        async function initLineupForPage() {
          if (window.DfsLineupStore) {
            await setupLineupStore();
          } else if (!CAN_EDIT && isCloudSlateKey(slateKey)) {
            syncUi();
          }
        }

        window.addEventListener(
          "dfs-lineup-store-ready",
          () => {
            initLineupForPage();
          },
          { once: true }
        );
        if (window.DfsLineupStore) {
          initLineupForPage();
        }
      };
      <% if (!(typeof clientSidePool !== 'undefined' && clientSidePool)) { %>
      window.initDfsLineupPage();
      <% } %>
    </script>
  </body>
</html>
