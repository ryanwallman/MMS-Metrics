<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/site-head") %>
  </head>
  <body>
    <%- include("partials/site-header") %>
    <main class="page-main">
    <h1 class="page-title">Roster Name Confirmation</h1>
    <p class="page-note">Source: <code>customRosters2026.js</code> vs closest in <code>data/csv/career.csv</code></p>
    <p class="page-note">Generated: <%= generatedAt %></p>
    <p><a href="/stats">Back to Stats</a></p>

    <div class="page-table-wrap">
    <table class="page-table" border="1" cellpadding="6" cellspacing="0">
      <thead>
        <tr>
          <th>#</th>
          <th>Team</th>
          <th>Roster Name</th>
          <th>Closest Career Name</th>
          <th>Similarity Score</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach((row, idx) => { %>
        <tr style="<%= row.matchType === 'none' ? 'background-color: #fecaca;' : (row.matchType === 'similar' ? 'background-color: #fef08a;' : '') %>">
          <td><%= idx + 1 %></td>
          <td><%= row.teamId %> - <%= row.teamName %></td>
          <td><%= row.playerName %></td>
          <td><%= row.closestCareerName %></td>
          <td><%= row.distance === null ? '' : row.distance.toFixed(3) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
    </main>
  </body>
</html>
