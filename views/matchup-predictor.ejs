<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/site-head") %>
  </head>
  <% const mmsMatchupLoading = typeof staticSite !== 'undefined' && staticSite && !(typeof matchupPageReady !== 'undefined' && matchupPageReady); %>
  <body<%= mmsMatchupLoading ? '' : ' class="mms-page-ready"' %>>
    <%- include("partials/site-header") %>

    <% if (mmsMatchupLoading) { %>
    <%- include("partials/mms-loading-screen", { showMmsLoadingScreen: true }) %>
    <% } %>

    <main class="page-main<%= mmsMatchupLoading ? ' mms-page-main--loading' : '' %>">
    <h1 class="page-title">Matchup Predictor</h1>

    <form
      method="GET"
      action="<%= sitePath('/matchup-predictor') %>"
      class="matchup-predictor-form"
      id="matchupForm"
      <% if (typeof selectedMatchup !== 'undefined' && selectedMatchup) { %>data-matchup-key="<%= selectedMatchup %>"<% } %>
    >
      <input type="hidden" name="awayMissing" id="awayMissing" value="<%= typeof awayMissingSerialized !== 'undefined' ? awayMissingSerialized : '' %>" />
      <input type="hidden" name="homeMissing" id="homeMissing" value="<%= typeof homeMissingSerialized !== 'undefined' ? homeMissingSerialized : '' %>" />
      <div class="matchup-predictor-controls">
        <label for="view">
          <strong>Date</strong>
          <select id="view" name="view" class="schedule-view-select">
            <% if (!scheduleOptions.length) { %>
            <option value="">No dates available</option>
            <% } %>
            <% scheduleOptions.forEach((opt) => { %>
            <option value="<%= opt.value %>" <%= opt.value === selectedView ? "selected" : "" %>>
              <%= opt.label %>
            </option>
            <% }) %>
          </select>
        </label>

        <label for="matchup">
          <strong>Matchup</strong>
          <select
            id="matchup"
            name="matchup"
            class="schedule-view-select"
            <%= matchupOptions.length ? "" : "disabled" %>
          >
            <option value="" <%= !selectedMatchup ? "selected" : "" %>>— Select a game —</option>
            <% matchupOptions.forEach((opt) => { %>
            <option value="<%= opt.value %>" <%= opt.value === selectedMatchup ? "selected" : "" %>>
              <%= opt.label %>
            </option>
            <% }) %>
          </select>
        </label>
      </div>
      <noscript><button type="submit">Go</button></noscript>

    <% if (scheduleSummary) { %>
    <p class="matchup-predictor-summary"><%= scheduleSummary %></p>
    <% } %>

    <% if (typeof gameResult !== 'undefined' && gameResult) { %>
    <% const gr = gameResult; const mp = gr.modelPrediction || {}; const bets = gr.bets || {}; %>
    <section class="matchup-prediction matchup-prediction--final">
      <h2>Final result</h2>
      <p class="matchup-prediction-note">
        This game is complete. Scores are from the schedule sheet. Model lines below are graded against the actual outcome.
      </p>

      <div class="matchup-pred-win-row matchup-pred-win-row--final">
        <div class="matchup-pred-team matchup-pred-away<%= gr.winnerSide === 'away' ? ' matchup-pred-team--winner' : '' %>">
          <span class="matchup-pred-team-name"><span class="matchup-side-tag">Away</span><%= gr.awayLabel %></span>
          <span class="matchup-pred-score"><%= gr.awayScore %></span>
        </div>
        <div class="matchup-pred-team matchup-pred-home<%= gr.winnerSide === 'home' ? ' matchup-pred-team--winner' : '' %>">
          <span class="matchup-pred-team-name"><span class="matchup-side-tag">Home</span><%= gr.homeLabel %></span>
          <span class="matchup-pred-score"><%= gr.homeScore %></span>
        </div>
      </div>

      <div class="page-table-wrap">
      <table class="matchup-pred-lines page-table">
        <thead>
          <tr>
            <th>Line</th>
            <th>Team / pick</th>
            <th>Value</th>
            <th>Result</th>
          </tr>
        </thead>
        <tbody>
          <tr class="matchup-lines-row--final-score">
            <td>Final score</td>
            <% if (gr.winnerSide === 'away') { %>
            <td class="matchup-lines-team matchup-lines-team--away matchup-lines-team--winner"><span class="matchup-side-tag matchup-side-tag--winner">Winner</span><%= gr.awayLabel %></td>
            <% } else if (gr.winnerSide === 'home') { %>
            <td class="matchup-lines-team matchup-lines-team--home matchup-lines-team--winner"><span class="matchup-side-tag matchup-side-tag--winner">Winner</span><%= gr.homeLabel %></td>
            <% } else { %>
            <td class="matchup-lines-team matchup-lines-team--both">Tie</td>
            <% } %>
            <td class="matchup-lines-value matchup-lines-score">
              <span class="matchup-score-runs <%= gr.winnerSide === 'away' ? 'matchup-score-runs--winner' : 'matchup-score-runs--loser' %>"><%= gr.awayScore %></span>
              <span class="matchup-score-sep">–</span>
              <span class="matchup-score-runs <%= gr.winnerSide === 'home' ? 'matchup-score-runs--winner' : 'matchup-score-runs--loser' %>"><%= gr.homeScore %></span>
            </td>
            <td class="matchup-bet-result">Actual</td>
          </tr>
          <% const ou = bets.overUnder || {}; %>
          <tr>
            <td>Over / under (total runs)</td>
            <td class="matchup-lines-team matchup-lines-team--both"><%= ou.pick === 'over' ? 'Over' : ou.pick === 'under' ? 'Under' : '—' %></td>
            <td class="matchup-lines-value"><strong>O/U <%= ou.line %></strong> <span class="matchup-bet-actual">(<%= gr.total %> runs)</span></td>
            <td class="matchup-bet-result"><%- include('partials/matchup-bet-status', { status: ou.status }) %></td>
          </tr>
          <% const rl = bets.runLine || {}; %>
          <% const rlSide = rl.side; %>
          <% const rlTeam = rlSide === 'away' ? gr.awayLabel : rlSide === 'home' ? gr.homeLabel : '—'; %>
          <tr class="matchup-lines-row--runline">
            <td>Run line</td>
            <% if (rlSide === 'away') { %>
            <td class="matchup-lines-team matchup-lines-team--away matchup-lines-team--favorite"><span class="matchup-side-tag">Away</span><%= gr.awayLabel %></td>
            <% } else if (rlSide === 'home') { %>
            <td class="matchup-lines-team matchup-lines-team--home matchup-lines-team--favorite"><span class="matchup-side-tag">Home</span><%= gr.homeLabel %></td>
            <% } else { %>
            <td class="matchup-lines-team">—</td>
            <% } %>
            <td class="matchup-lines-value"><strong><%= rl.line %></strong></td>
            <td class="matchup-bet-result"><%- include('partials/matchup-bet-status', { status: rl.status }) %></td>
          </tr>
          <% const ml = bets.moneyline || {}; %>
          <% const mlAway = bets.moneylineAway || {}; %>
          <% const mlHome = bets.moneylineHome || {}; %>
          <tr>
            <td>Moneyline</td>
            <td class="matchup-lines-team matchup-lines-team--away"><span class="matchup-side-tag">Away</span><%= gr.awayLabel %><% if (ml.favoriteSide === 'away') { %> <span class="matchup-bet-model-pick">Model pick</span><% } %></td>
            <td class="matchup-lines-value"><strong><%= mp.lines && mp.lines.moneylineAway ? mp.lines.moneylineAway : '—' %></strong></td>
            <td class="matchup-bet-result"><%- include('partials/matchup-bet-status', { status: mlAway.status }) %></td>
          </tr>
          <tr>
            <td>Moneyline</td>
            <td class="matchup-lines-team matchup-lines-team--home"><span class="matchup-side-tag">Home</span><%= gr.homeLabel %><% if (ml.favoriteSide === 'home') { %> <span class="matchup-bet-model-pick">Model pick</span><% } %></td>
            <td class="matchup-lines-value"><strong><%= mp.lines && mp.lines.moneylineHome ? mp.lines.moneylineHome : '—' %></strong></td>
            <td class="matchup-bet-result"><%- include('partials/matchup-bet-status', { status: mlHome.status }) %></td>
          </tr>
        </tbody>
      </table>
      </div>
    </section>
    <% } else if (prediction) { %>
    <section class="matchup-prediction">
      <h2>Model prediction</h2>
      <p class="matchup-prediction-note">
        <strong>Expected runs</strong> use roster offense, 2026 production, schedule runs per game and runs against,
        plus how many runs the opponent typically allows. <strong>Win %</strong> is driven mainly by the projected run margin
        (a 2-run edge is a modest favorite, not a blowout); roster/record talent is a smaller secondary input. No artificial cap on win %.
      </p>

      <% const awayWinPct = prediction.winPct.away; const homeWinPct = prediction.winPct.home; %>
      <% const awayTeamName = prediction.awayLabel || (typeof selectedGame !== "undefined" && selectedGame ? selectedGame.away : "Away"); %>
      <% const homeTeamName = prediction.homeLabel || (typeof selectedGame !== "undefined" && selectedGame ? selectedGame.home : "Home"); %>
      <div class="matchup-pred-win-row">
        <div class="matchup-pred-team matchup-pred-away">
          <span class="matchup-pred-team-name"><span class="matchup-side-tag">Away</span><%= awayTeamName %></span>
          <span class="matchup-pred-pct"><%= awayWinPct %>%</span>
          <span class="matchup-pred-bar-wrap"><span class="matchup-pred-bar <%= awayWinPct >= homeWinPct ? 'matchup-pred-bar--leader' : 'matchup-pred-bar--trailer' %>" style="width:<%= awayWinPct %>%"></span></span>
        </div>
        <div class="matchup-pred-team matchup-pred-home">
          <span class="matchup-pred-team-name"><span class="matchup-side-tag">Home</span><%= homeTeamName %></span>
          <span class="matchup-pred-pct"><%= homeWinPct %>%</span>
          <span class="matchup-pred-bar-wrap"><span class="matchup-pred-bar <%= homeWinPct >= awayWinPct ? 'matchup-pred-bar--leader' : 'matchup-pred-bar--trailer' %>" style="width:<%= homeWinPct %>%"></span></span>
        </div>
      </div>

      <div class="page-table-wrap">
      <table class="matchup-pred-lines page-table">
        <thead>
          <tr>
            <th>Line</th>
            <th>Team</th>
            <th>Value</th>
          </tr>
        </thead>
        <tbody>
          <% const finalScore = prediction.lines.finalScore || {}; %>
          <% let winnerSide = finalScore.winnerSide; %>
          <% if (!winnerSide) { winnerSide = homeWinPct > awayWinPct ? 'home' : (awayWinPct > homeWinPct ? 'away' : (homeWinPct >= awayWinPct ? 'home' : 'away')); } %>
          <tr class="matchup-lines-row--final-score">
            <td>Predicted final score</td>
            <% if (winnerSide === 'away') { %>
            <td class="matchup-lines-team matchup-lines-team--away matchup-lines-team--winner"><span class="matchup-side-tag matchup-side-tag--winner">Winner</span><%= awayTeamName %></td>
            <% } else { %>
            <td class="matchup-lines-team matchup-lines-team--home matchup-lines-team--winner"><span class="matchup-side-tag matchup-side-tag--winner">Winner</span><%= homeTeamName %></td>
            <% } %>
            <td class="matchup-lines-value matchup-lines-score">
              <span class="matchup-score-runs <%= winnerSide === 'away' ? 'matchup-score-runs--winner' : 'matchup-score-runs--loser' %>"><%= prediction.projectedRuns.away %></span>
              <span class="matchup-score-sep">–</span>
              <span class="matchup-score-runs <%= winnerSide === 'home' ? 'matchup-score-runs--winner' : 'matchup-score-runs--loser' %>"><%= prediction.projectedRuns.home %></span>
            </td>
          </tr>
          <tr>
            <td>Over / under (total runs)</td>
            <td class="matchup-lines-team matchup-lines-team--both">Both teams</td>
            <td class="matchup-lines-value"><strong>O/U <%= prediction.lines.overUnder %></strong></td>
          </tr>
          <% const runLine = prediction.lines.runLine || {}; %>
          <% let runLineSide = runLine.side; %>
          <% if (!runLineSide) { runLineSide = homeWinPct > awayWinPct ? 'home' : (awayWinPct > homeWinPct ? 'away' : (homeWinPct >= awayWinPct ? 'home' : 'away')); } %>
          <% let runLineValue = runLine.value; %>
          <% if (!runLineValue || runLineValue === '—') {
            const awayRunsNum = parseFloat(prediction.projectedRuns.away);
            const homeRunsNum = parseFloat(prediction.projectedRuns.home);
            if (!isNaN(awayRunsNum) && !isNaN(homeRunsNum)) {
              let mag = Math.abs(homeRunsNum - awayRunsNum);
              if (mag < 1e-9) mag = 0.5;
              runLineValue = Math.abs(mag % 1) < 1e-9 ? String(Math.round(mag)) : mag.toFixed(1);
            } else {
              runLineValue = '—';
            }
          } %>
          <tr class="matchup-lines-row--runline">
            <td>Run line</td>
            <% if (runLineSide === 'away') { %>
            <td class="matchup-lines-team matchup-lines-team--away matchup-lines-team--favorite"><span class="matchup-side-tag">Away</span><%= awayTeamName %></td>
            <% } else { %>
            <td class="matchup-lines-team matchup-lines-team--home matchup-lines-team--favorite"><span class="matchup-side-tag">Home</span><%= homeTeamName %></td>
            <% } %>
            <td class="matchup-lines-value"><strong><%= runLineValue %></strong></td>
          </tr>
          <tr>
            <td>Moneyline</td>
            <td class="matchup-lines-team matchup-lines-team--away"><span class="matchup-side-tag">Away</span><%= awayTeamName %></td>
            <td class="matchup-lines-value"><strong><%= prediction.lines.moneylineAway %></strong></td>
          </tr>
          <tr>
            <td>Moneyline</td>
            <td class="matchup-lines-team matchup-lines-team--home"><span class="matchup-side-tag">Home</span><%= homeTeamName %></td>
            <td class="matchup-lines-value"><strong><%= prediction.lines.moneylineHome %></strong></td>
          </tr>
        </tbody>
      </table>
      </div>
    </section>
    <% } %>

    <div id="matchup-lineup-rules-host">
    <% if (typeof lineupRuleAlerts !== 'undefined' && lineupRuleAlerts.length) { %>
    <% const batsTwiceAlerts = lineupRuleAlerts.filter((a) => a.doubleBatter); %>
    <% const rosterNoteAlerts = lineupRuleAlerts.filter((a) => !a.doubleBatter); %>
    <% if (batsTwiceAlerts.length) { %>
    <section class="matchup-lineup-alerts matchup-bats-twice-section" aria-label="Bats twice in the lineup">
      <h2 class="matchup-lineup-alerts-title">Bats twice in the lineup</h2>
      <% batsTwiceAlerts.forEach((alert) => { %>
      <% const db = alert.doubleBatter; const imp = db && db.impact; %>
      <div class="matchup-lineup-alert matchup-lineup-alert--rule matchup-lineup-alert--double-batter">
        <p class="matchup-lineup-alert-team"><span class="matchup-side-tag"><%= alert.teamSide === 'away' ? 'Away' : 'Home' %></span> <%= alert.teamName %></p>
        <p class="matchup-lineup-alert-heading"><strong><%= alert.title %></strong></p>
        <p class="matchup-lineup-alert-msg"><%= alert.message %></p>
        <div class="matchup-double-batter-card">
          <p class="matchup-double-batter-who">
            <span class="matchup-double-batter-badge">2× in lineup</span>
            <strong><%= db.name %></strong>
            <span class="matchup-double-batter-meta">(Round <%= db.round %> pick)</span>
          </p>
          <p class="matchup-double-batter-reason"><%= db.reason %></p>
          <% if (imp) { %>
          <% if (imp.missingNamesLabel) { %>
          <p class="matchup-double-batter-missing"><strong>Out of lineup:</strong> <%= imp.missingNamesLabel %></p>
          <% } %>
          <dl class="matchup-double-batter-stats">
            <div class="matchup-double-batter-stat">
              <dt>Offensive +/-</dt>
              <dd><%= imp.offensiveRatingLabel != null ? imp.offensiveRatingLabel : '—' %></dd>
            </div>
            <div class="matchup-double-batter-stat">
              <dt>2026 run production</dt>
              <dd><%= imp.runProdLabel != null ? imp.runProdLabel + ' R+RBI per PA' : '—' %></dd>
            </div>
            <% if (imp.lineupSharePctOneTurn != null && imp.lineupSharePctTwoTurns != null) { %>
            <div class="matchup-double-batter-stat">
              <dt>Lineup weight</dt>
              <dd><%= imp.lineupSharePctOneTurn %>% → <strong><%= imp.lineupSharePctTwoTurns %>%</strong> of team offense</dd>
            </div>
            <% } %>
          </dl>
          <p class="matchup-double-batter-effect">
            <strong>Prediction impact:</strong>
            Missing players still hurt — the extra turn only partly fills the gap.
            <% if (imp.replacementRatingLabel) { %>
            Average offensive +/- of who's out: <strong><%= imp.replacementRatingLabel %></strong>.
            <%= db.name %> is <strong><%= imp.offensiveRatingLabel || '—' %></strong> (gap <strong><%= imp.gapRatingLabel || '—' %></strong> vs missing).
            <% } %>
            The model credits <strong><%= imp.secondTurnPct %>%</strong> of a full extra lineup turn (not automatic 2×).
            <% if (imp.comparisonVerdict === 'much-weaker' || imp.comparisonVerdict === 'weaker') { %>
            <strong><%= db.name %> is not as strong as who's missing</strong> — batting twice does not make this lineup stronger overall.
            <% } else if (imp.comparisonVerdict === 'much-better' || imp.comparisonVerdict === 'better') { %>
            <strong><%= db.name %> is stronger than the missing hitters on average</strong> — the second turn helps offset some of the loss.
            <% } else { %>
            The second turn is roughly a wash compared to the production lost from missing players.
            <% } %>
            <% if (imp.offenseRatingBoost != null && imp.offenseRatingBoost > 0.005) { %>
            Net change to projected offense: <strong>+<%= imp.offenseRatingBoostLabel && imp.offenseRatingBoostLabel.replace('+','') %></strong><% if (imp.runProdBoost != null && imp.runProdBoost > 0.0005) { %>, run production <strong><%= imp.runProdBoostLabel %></strong><% } %>.
            <% } else if (imp.offenseRatingBoost != null && imp.offenseRatingBoost < -0.005) { %>
            Net change to projected offense: <strong><%= imp.offenseRatingBoostLabel %></strong>.
            <% } %>
          </p>
          <% } %>
        </div>
      </div>
      <% }) %>
    </section>
    <% } %>
    <% if (rosterNoteAlerts.length) { %>
    <section class="matchup-roster-notes" aria-label="Roster notes">
      <h2 class="matchup-roster-notes-title">Roster notes (MMS bylaws)</h2>
      <% rosterNoteAlerts.forEach((alert) => { %>
      <div class="matchup-lineup-alert matchup-lineup-alert--<%= alert.severity %>">
        <p class="matchup-lineup-alert-team"><span class="matchup-side-tag"><%= alert.teamSide === 'away' ? 'Away' : 'Home' %></span> <%= alert.teamName %></p>
        <p class="matchup-lineup-alert-heading"><strong><%= alert.title %></strong></p>
        <p class="matchup-lineup-alert-msg"><%= alert.message %></p>
      </div>
      <% }) %>
    </section>
    <% } %>
    <% } %>
    </div>

    <% if (selectedGame) { %>
    <% const rosterAwayName = (awayRoster && awayRoster.teamName) || selectedGame.away; %>
    <% const rosterHomeName = (homeRoster && homeRoster.teamName) || selectedGame.home; %>
    <% const isFinishedGame = typeof gameResult !== 'undefined' && gameResult; %>
    <section class="matchup-predictor-rosters">
      <% if (!isFinishedGame) { %>
      <p class="matchup-roster-hint">Toggle <strong>Active</strong> / <strong>Bench</strong> for each player. Bench choices are saved in your browser for this matchup (local storage). Win % and lineup rules follow MMS bylaws for missing players, C-players, and the 2026 11-batter rule.</p>
      <% } else { %>
      <p class="matchup-roster-hint">Rosters shown as they were tracked for this completed game.</p>
      <% } %>
      <h2 class="matchup-predictor-headline">
        <span class="matchup-headline-team matchup-headline-team--away"><span class="matchup-side-tag">Away</span><%= rosterAwayName %></span>
        <span class="matchup-predictor-at">@</span>
        <span class="matchup-headline-team matchup-headline-team--home"><span class="matchup-side-tag">Home</span><%= rosterHomeName %></span>
      </h2>
      <div class="schedule-roster-pair matchup-predictor-pair">
        <%- include('partials/matchup-roster-col', { roster: awayRoster, side: 'away', teamName: rosterAwayName }) %>
        <%- include('partials/matchup-roster-col', { roster: homeRoster, side: 'home', teamName: rosterHomeName }) %>
      </div>
    </section>
    <% } else if (selectedView && matchupOptions.length && !selectedMatchup) { %>
    <p class="matchup-predictor-prompt">Choose a matchup above to see both teams and their rosters.</p>
    <% } else if (selectedView && !matchupOptions.length) { %>
    <p class="matchup-predictor-prompt">No games listed for this date.</p>
    <% } %>

    </form>
    </main>
    <% if (typeof staticSite !== 'undefined' && staticSite) { %>
    <script type="module" src="<%= sitePath('/js/matchup-predictor-nav.mjs') %>?v=<%= assetVersion %>"></script>
    <% } %>
    <% if (typeof matchupClient !== 'undefined' && matchupClient) { %>
    <script>window.__MATCHUP_CLIENT__ = <%- JSON.stringify(matchupClient) %>;</script>
    <script src="<%= sitePath('/js/matchup-predictor-ui.js') %>?v=<%= assetVersion %>"></script>
    <script type="module" src="<%= sitePath('/js/matchup-predictor-client.mjs') %>?v=<%= assetVersion %>"></script>
    <% } %>
    <script>
      (function () {
        const form = document.getElementById("matchupForm");
        const awayInput = document.getElementById("awayMissing");
        const homeInput = document.getElementById("homeMissing");
        const viewSelect = document.getElementById("view");
        const matchupSelect = document.getElementById("matchup");
        if (!form || !awayInput || !homeInput || !viewSelect || !matchupSelect) return;
        const isStaticSite = <%= staticSite ? "true" : "false" %>;

        const STORAGE_PREFIX = "mms-matchup-lineup:";
        const matchupKey = form.getAttribute("data-matchup-key") || "";
        const matchupCtx = window.__MATCHUP_CLIENT__ || null;
        const isFinishedGame = !!(matchupCtx && matchupCtx.isFinishedGame);

        function parseList(value) {
          return value
            .split(",")
            .map((s) => s.trim())
            .filter(Boolean);
        }

        function benchSortedKey(arr) {
          return [...arr].map((s) => String(s || "").trim()).filter(Boolean).sort().join(",");
        }

        function matchupKeyToSlug(key) {
          const k = (key || "").trim();
          const pipe = k.indexOf("|");
          if (pipe < 0) return k;
          return k.slice(0, pipe) + "-" + k.slice(pipe + 1);
        }

        function redirectLegacyMatchupPath() {
          if (!isStaticSite) return false;
          const p = window.location.pathname;
          const m = p.match(/\/matchup\/([^/?#]+)/);
          if (!m) return false;
          const seg = m[1];
          if (!seg.includes("%7C") && !seg.includes("|")) return false;
          let decoded = seg;
          try {
            decoded = decodeURIComponent(seg);
          } catch {
            /* keep seg */
          }
          const parts = decoded.split("|");
          if (parts.length !== 2 || !/^\d+$/.test(parts[0]) || !/^\d+$/.test(parts[1])) return false;
          const slug = parts[0] + "-" + parts[1];
          const next = p.replace(/\/matchup\/[^/?#]+/, "/matchup/" + slug) + window.location.search;
          window.location.replace(next);
          return true;
        }

        if (redirectLegacyMatchupPath()) return;

        function submitOrNavigate() {
          if (!isStaticSite) {
            form.requestSubmit();
            return;
          }
          const view = (viewSelect.value || "").trim();
          const matchup = (matchupSelect.value || "").trim();
          let path = "<%= sitePath('/matchup-predictor') %>";
          if (view) {
            path += "/view/" + encodeURIComponent(view);
            if (matchup) path += "/matchup/" + matchupKeyToSlug(matchup);
          }
          const params = new URLSearchParams();
          if (awayInput.value) params.set("awayMissing", awayInput.value);
          if (homeInput.value) params.set("homeMissing", homeInput.value);
          const qs = params.toString();
          window.location.assign(qs ? path + "?" + qs : path);
        }

        if (isStaticSite && !window.location.pathname.includes("/view/")) {
          const url = new URL(window.location.href);
          const queryView = (url.searchParams.get("view") || "").trim();
          const queryMatchup = (url.searchParams.get("matchup") || "").trim();
          const queryAwayMissing = (url.searchParams.get("awayMissing") || "").trim();
          const queryHomeMissing = (url.searchParams.get("homeMissing") || "").trim();
          if (queryView) viewSelect.value = queryView;
          if (queryMatchup) {
            const pipe = queryMatchup.indexOf("|");
            matchupSelect.value = pipe >= 0
              ? queryMatchup.slice(0, pipe) + "|" + queryMatchup.slice(pipe + 1)
              : queryMatchup.replace(/^(\d+)-(\d+)$/, "$1|$2");
          }
          if (queryAwayMissing) awayInput.value = queryAwayMissing;
          if (queryHomeMissing) homeInput.value = queryHomeMissing;
          if (queryView || queryMatchup) {
            submitOrNavigate();
            return;
          }
        }

        function loadStoredBench() {
          if (!matchupKey) return { awayBench: [], homeBench: [] };
          try {
            const raw = localStorage.getItem(STORAGE_PREFIX + matchupKey);
            if (!raw) return { awayBench: [], homeBench: [] };
            const data = JSON.parse(raw);
            const away = data.awayBench ?? data.away;
            const home = data.homeBench ?? data.home;
            return {
              awayBench: Array.isArray(away) ? away : [],
              homeBench: Array.isArray(home) ? home : [],
            };
          } catch {
            return { awayBench: [], homeBench: [] };
          }
        }

        function saveStoredBench(awayBench, homeBench) {
          if (!matchupKey) return;
          localStorage.setItem(
            STORAGE_PREFIX + matchupKey,
            JSON.stringify({
              version: 1,
              awayBench: [...awayBench],
              homeBench: [...homeBench],
              updatedAt: new Date().toISOString(),
            })
          );
        }

        function applyBenchToForm(awayBench, homeBench) {
          awayInput.value = awayBench.join(",");
          homeInput.value = homeBench.join(",");
        }

        function syncButtons(awaySet, homeSet) {
          document.querySelectorAll("[data-lineup-toggle]").forEach((btn) => {
            const side = btn.getAttribute("data-side");
            const norm = btn.getAttribute("data-norm");
            const onBench = (side === "away" ? awaySet : homeSet).has(norm);
            btn.textContent = onBench ? "Bench" : "Active";
            btn.classList.toggle("matchup-status-btn--active", !onBench);
            btn.classList.toggle("matchup-status-btn--missing", onBench);
            btn.setAttribute("aria-pressed", onBench ? "true" : "false");
            const row = btn.closest(".matchup-roster-item");
            if (row) row.classList.toggle("matchup-roster-item--benched", onBench);
          });
        }

        let awaySet = new Set(parseList(awayInput.value));
        let homeSet = new Set(parseList(homeInput.value));

        if (matchupKey) {
          const stored = loadStoredBench();
          const hasStored =
            stored.awayBench.length > 0 || stored.homeBench.length > 0;
          const serverAway = benchSortedKey([...awaySet]);
          const serverHome = benchSortedKey([...homeSet]);
          const storedAway = benchSortedKey(stored.awayBench);
          const storedHome = benchSortedKey(stored.homeBench);

          if (isStaticSite || hasStored) {
            if (storedAway !== serverAway || storedHome !== serverHome) {
              awaySet = new Set(stored.awayBench);
              homeSet = new Set(stored.homeBench);
              applyBenchToForm(stored.awayBench, stored.homeBench);
              if (!isStaticSite && !matchupCtx) {
                submitOrNavigate();
                return;
              }
            }
          } else if (awaySet.size || homeSet.size) {
            saveStoredBench([...awaySet], [...homeSet]);
          }
        }

        if (isStaticSite && matchupKey) {
          const url = new URL(window.location.href);
          if (url.searchParams.has("awayMissing") || url.searchParams.has("homeMissing")) {
            url.searchParams.delete("awayMissing");
            url.searchParams.delete("homeMissing");
            window.history.replaceState({}, "", url.pathname + (url.search || ""));
          }
        }

        function recalcPrediction() {
          if (isFinishedGame) return;
          if (!matchupCtx || !window.MmsMatchupPredictor || !window.MmsMatchupPredictorUi) return;
          try {
            const awayBench = [...awaySet];
            const homeBench = [...homeSet];
            const pred = window.MmsMatchupPredictor.predictFromPayload(
              matchupCtx,
              awayBench,
              homeBench
            );
            window.MmsMatchupPredictorUi.updatePredictionUi(pred);
            const awayTotal = matchupCtx.awayPlayers ? matchupCtx.awayPlayers.length : 0;
            const homeTotal = matchupCtx.homePlayers ? matchupCtx.homePlayers.length : 0;
            window.MmsMatchupPredictorUi.updateActiveCounts(
              awayTotal - awaySet.size,
              homeTotal - homeSet.size,
              awayTotal,
              homeTotal
            );
            if (window.MmsMatchupPredictor.buildLineupEnrichment) {
              const enrichment = window.MmsMatchupPredictor.buildLineupEnrichment(
                matchupCtx,
                awayBench,
                homeBench
              );
              window.MmsMatchupPredictorUi.updateLineupUi(enrichment);
            }
          } catch (err) {
            console.error("Matchup prediction update failed", err);
          }
        }

        function normName(value) {
          return String(value || "")
            .toLowerCase()
            .replace(/[.'’]/g, "")
            .replace(/\s+/g, " ")
            .trim();
        }

        function remapBenchSet(set, replacementMap) {
          const out = new Set();
          for (const n of set) {
            const key = normName(n);
            const repl = replacementMap.get(key);
            out.add(repl ? repl.replacementNorm : key);
          }
          return out;
        }

        function replacementMapFromCtx(ctx) {
          const map = new Map();
          for (const [norm, entry] of Object.entries(ctx?.replacementByOriginalNorm || {})) {
            if (entry?.replacementNorm) map.set(norm, entry);
          }
          return map;
        }

        async function initMatchupClient() {
          const replMap = replacementMapFromCtx(matchupCtx);
          if (replMap.size) {
            awaySet = remapBenchSet(awaySet, replMap);
            homeSet = remapBenchSet(homeSet, replMap);
            applyBenchToForm([...awaySet], [...homeSet]);
          }

          if (
            isStaticSite &&
            matchupCtx &&
            window.MmsMatchupPredictor?.hydrateMatchupReplacements
          ) {
            try {
              await window.MmsMatchupPredictor.hydrateMatchupReplacements(matchupCtx);
              const liveReplMap = replacementMapFromCtx(matchupCtx);
              if (window.MmsMatchupPredictorUi?.applyReplacementDisplay) {
                window.MmsMatchupPredictorUi.applyReplacementDisplay(
                  matchupCtx.awayPlayersOriginal,
                  "away",
                  liveReplMap
                );
                window.MmsMatchupPredictorUi.applyReplacementDisplay(
                  matchupCtx.homePlayersOriginal,
                  "home",
                  liveReplMap
                );
              }
              if (liveReplMap.size) {
                awaySet = remapBenchSet(awaySet, liveReplMap);
                homeSet = remapBenchSet(homeSet, liveReplMap);
                applyBenchToForm([...awaySet], [...homeSet]);
              }
            } catch (err) {
              console.error("Matchup replacement hydrate failed", err);
            }
          }
          syncButtons(awaySet, homeSet);
          if (matchupCtx) recalcPrediction();
        }

        initMatchupClient();

        viewSelect.addEventListener("change", () => {
          matchupSelect.value = "";
          submitOrNavigate();
        });

        matchupSelect.addEventListener("change", () => {
          submitOrNavigate();
        });

        document.querySelectorAll("[data-lineup-toggle]").forEach((btn) => {
          if (isFinishedGame) {
            btn.disabled = true;
            btn.setAttribute("aria-disabled", "true");
            return;
          }
          btn.addEventListener("click", () => {
            const side = btn.getAttribute("data-side");
            const norm = btn.getAttribute("data-norm");
            const set = side === "away" ? awaySet : homeSet;
            if (set.has(norm)) set.delete(norm);
            else set.add(norm);
            applyBenchToForm([...awaySet], [...homeSet]);
            saveStoredBench([...awaySet], [...homeSet]);
            syncButtons(awaySet, homeSet);
            if (matchupCtx) recalcPrediction();
            else if (!isStaticSite) submitOrNavigate();
          });
        });
      })();
    </script>
  </body>
</html>


