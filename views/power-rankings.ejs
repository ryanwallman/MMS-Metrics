<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/site-head") %>
  </head>
  <body>
    <%- include("partials/site-header") %>

    <% if (typeof clientSidePowerRankings !== 'undefined' && clientSidePowerRankings) { %>
    <%- include("partials/mms-loading-screen", { showMmsLoadingScreen: true }) %>
    <% } %>

    <main class="page-main<%= (typeof clientSidePowerRankings !== 'undefined' && clientSidePowerRankings) ? ' mms-page-main--loading' : '' %>">
    <% const teamBlend = typeof teamOverallWeights !== 'undefined' ? teamOverallWeights : { player: 0.4, record: 0.45, sos: 0.15 }; %>
    <h1 class="page-title">Power Rankings</h1>

    <% if (typeof clientSidePowerRankings !== 'undefined' && clientSidePowerRankings) { %>
    <div id="powerRankingsRoot" aria-busy="true" aria-live="polite"></div>
    <script>
      window.__MMS_CAREER_CSV_URL__ = "<%= sitePath('/data/csv/career.csv') %>";
    </script>
    <script type="module" src="<%= sitePath('/js/power-rankings.js') %>?v=<%= assetVersion %>"></script>
    <% } else { %>

    <section class="rankings-explainer power-rankings-explainer">
      <h2>How this works</h2>
      <p>
        <strong>Current power</strong> uses the same team blend as offensive rankings:
        <strong><%= Math.round(teamBlend.player * 100) %>%</strong> roster talent (2026 PA–weighted player ratings),
        <strong><%= Math.round(teamBlend.record * 100) %>%</strong> record (win % z-score),
        <strong><%= Math.round(teamBlend.sos * 100) %>%</strong> strength of schedule (avg. opponent win %).
      </p>
      <p>
        <strong>Season projections</strong> start from each team’s current W-L, then add
        <em>expected</em> wins and losses on every remaining game using the
        <a href="<%= sitePath('/matchup-predictor') %>">matchup predictor</a> model
        (roster offense, schedule runs for/against, active vs benched players).
        Projected win % keeps fractional expected wins; the W-L column rounds to whole numbers. Regular season length:
        <strong><%= regularSeasonGames %> games</strong>.
      </p>
      <% if (remainingGamesTotal > 0) { %>
      <p style="margin-bottom: 0;">
        <strong><%= remainingGamesSimulated %></strong> of <strong><%= remainingGamesTotal %></strong> unplayed
        schedule games were simulated (games missing roster data are skipped).
      </p>
      <% } %>
    </section>

    <section class="power-rankings-section">
      <h2>Current power rankings</h2>
      <p class="power-rankings-note">
        Sorted by blended team power rating (higher = stronger right now).
        <span class="power-heat-legend">Win % and SOS are color-coded: green = higher win % or easier schedule; red = lower win % or tougher schedule.</span>
      </p>
      <div class="rankings-table-wrap">
        <table class="rankings-master-table page-table power-rankings-table">
          <thead>
            <tr>
              <th>Rank</th>
              <th>Team</th>
              <th>Captain</th>
              <th>Power</th>
              <th>Record</th>
              <th>Win %</th>
              <th>SOS</th>
              <th>Roster</th>
              <th>GP</th>
            </tr>
          </thead>
          <tbody>
            <% currentRankings.forEach((t) => { %>
            <tr>
              <td style="text-align: right"><%= t.rank %></td>
              <td><%= t.teamName %> (#<%= t.teamId %>)</td>
              <td><%= t.captain || "—" %></td>
              <td style="text-align: right">
                <strong><%= t.powerRating >= 0 ? "+" + t.powerRating.toFixed(2) : t.powerRating.toFixed(2) %></strong>
              </td>
              <td style="text-align: right"><%= t.wins %>-<%= t.losses %></td>
              <td class="power-heat-cell" style="<%= ['text-align: right', t.winPctHeatStyle].filter(Boolean).join('; ') %>">
                <%= t.winPct != null ? (t.winPct * 100).toFixed(1) + "%" : "—" %>
              </td>
              <td class="power-heat-cell" style="<%= ['text-align: right', t.sosHeatStyle].filter(Boolean).join('; ') %>">
                <%= t.sosOppWinPct != null ? (t.sosOppWinPct * 100).toFixed(1) + "%" : "—" %>
              </td>
              <td style="text-align: right">
                <%= t.rosterRating >= 0 ? "+" + t.rosterRating.toFixed(2) : t.rosterRating.toFixed(2) %>
              </td>
              <td style="text-align: right"><%= t.gamesPlayed %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="power-rankings-section">
      <h2 class="power-rankings-projection-title">
        Projected final standings (<%= regularSeasonGames %>-game season)
      </h2>
      <p class="power-rankings-note">
        Sorted by projected wins. “Proj. W-L” rounds expected totals; “Proj. win %” uses fractional wins.
        Remaining games use the same stats-based matchup model as the predictor page.
      </p>
      <div class="rankings-table-wrap">
        <table class="rankings-master-table page-table power-rankings-table">
          <thead>
            <tr>
              <th>Proj. rank</th>
              <th>Team</th>
              <th>Captain</th>
              <th>Current</th>
              <th>Proj. W-L</th>
              <th>Proj. win %</th>
              <th>Exp. rest</th>
              <th>Power rank now</th>
            </tr>
          </thead>
          <tbody>
            <% projectionRows.forEach((t) => { %>
            <tr>
              <td style="text-align: right"><%= t.projectedRank %></td>
              <td><%= t.teamName %> (#<%= t.teamId %>)</td>
              <td><%= t.captain || "—" %></td>
              <td style="text-align: right"><%= t.currentWins %>-<%= t.currentLosses %></td>
              <td style="text-align: right"><strong><%= t.projectedRecord %></strong></td>
              <td style="text-align: right">
                <%= t.projectedWinPct != null ? t.projectedWinPct.toFixed(1) + "%" : "—" %>
              </td>
              <td style="text-align: right" title="Rounded projected W-L minus current record">
                <%= t.expRestRecord %>
              </td>
              <td style="text-align: right"><%= t.currentPowerRank != null ? t.currentPowerRank : "—" %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
    <% } %>
    </main>
  </body>
</html>
