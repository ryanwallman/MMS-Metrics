<!DOCTYPE html>
<% const canLoadStandings = (typeof leaderboardServerRead !== 'undefined' && leaderboardServerRead) || (typeof firebaseEnabled !== 'undefined' && firebaseEnabled); %>
<% const serverRendered = typeof serverRenderedStandings !== 'undefined' && serverRenderedStandings; %>
<% const lbSlateLocked = (typeof slateLocked !== 'undefined' && slateLocked) || (slate && slate.canEdit !== true); %>
<% const tableColspan = lbSlateLocked ? 4 : 3; %>
<html lang="en">
  <head>
    <%- include("partials/site-head") %>
    <title>DFS Leaderboard — Marlboro Men's Softball</title>
  </head>
  <body class="dfs-leaderboard-page<%= serverRendered ? ' leaderboard-ready' : '' %>">
    <%- include("partials/site-header") %>

    <% if (canLoadStandings && !serverRendered) { %>
    <div
      id="leaderboardLoadingScreen"
      class="dfs-leaderboard-loading-screen"
      role="status"
      aria-live="polite"
      aria-busy="true"
      aria-label="Loading leaderboard"
    >
      <div class="dfs-leaderboard-loading-screen__panel">
        <div class="dfs-leaderboard-loading-screen__spinner" aria-hidden="true"></div>
        <h2 class="dfs-leaderboard-loading-screen__title">Loading leaderboard</h2>
      </div>
    </div>
    <% } %>

    <main class="page-main dfs-page dfs-leaderboard-page<%= canLoadStandings && !serverRendered ? ' dfs-leaderboard-page--loading' : '' %>">
      <div class="dfs-page-head">
        <h1 class="page-title">DFS Leaderboard</h1>
        <p class="dfs-page-head-actions">
          <a href="<%= sitePath('/dfs') %>" class="dfs-btn">← Lineup builder</a>
        </p>
      </div>

      <p class="page-note dfs-intro">
        Saved lineups for the selected slate are loaded from Firebase and ranked by total fantasy points.
        Scoring uses the same per-player slate points shown on the <a href="<%= sitePath('/dfs') %>">DFS Lineup Builder</a> player pool (sum of those eight values per lineup).
        <% if (!lbSlateLocked) { %> Salary stays hidden until the slate locks.<% } else { %> Tap a name to view that player’s saved lineup.<% } %>
      </p>

      <% if (!canLoadStandings) { %>
      <section class="dfs-leaderboard-alert dfs-leaderboard-alert--error" role="status">
        <p>
          <strong>Standings cannot load yet.</strong>
          Set <code>FIREBASE_*</code> in <code>.env</code>, run <code>npm run build:pages</code>, and push <code>docs/</code>. The leaderboard loads lineups from Firestore in your browser.
        </p>
      </section>
      <% } else if (typeof weeklyStandingsError !== 'undefined' && weeklyStandingsError) { %>
      <section class="dfs-leaderboard-alert dfs-leaderboard-alert--error" role="status">
        <p><strong><%= weeklyStandingsError %></strong> The page will try loading via your browser below.</p>
      </section>
      <% } %>

      <section class="dfs-leaderboard-alert" id="leaderboardStatus" role="status" aria-live="polite" hidden></section>

      <% if (typeof staticSite !== 'undefined' && staticSite) { %>
      <div class="dfs-slate-form dfs-leaderboard-week-form">
        <label for="week">
          <strong>Slate</strong>
          <select id="week" name="week" onchange="location.assign(this.options[this.selectedIndex].dataset.href)">
            <% weekOptions.forEach((opt) => { %>
            <option
              value="<%= opt.value %>"
              data-href="<%= sitePath('/dfs/leaderboard/week/' + encodeURIComponent(opt.value)) %>"
              <%= opt.value === selectedWeek ? 'selected' : '' %>
            >
              <%= opt.label %><%= opt.isPast ? '' : ' (upcoming)' %>
            </option>
            <% }) %>
          </select>
        </label>
      </div>
      <% } else { %>
      <form method="GET" action="<%= sitePath('/dfs/leaderboard') %>" class="dfs-slate-form dfs-leaderboard-week-form">
        <label for="week">
          <strong>Slate</strong>
          <select id="week" name="week" onchange="this.form.submit()">
            <% weekOptions.forEach((opt) => { %>
            <option value="<%= opt.value %>" <%= opt.value === selectedWeek ? 'selected' : '' %>>
              <%= opt.label %><%= opt.isPast ? '' : ' (upcoming)' %>
            </option>
            <% }) %>
          </select>
        </label>
      </form>
      <% } %>

      <% if (slate) { %>
      <section class="dfs-slate-banner" aria-label="Selected slate">
        <h2 class="dfs-slate-title"><%= slate.label %></h2>
        <% if (!slate.isPast) { %>
        <p class="dfs-slate-status" id="weeklySlateStatus"><%= slate.slateType === 'wednesday'
          ? "This slate has not finished yet — points appear after Wednesday’s games."
          : "This week has not finished yet — points appear after Sunday’s games." %></p>
        <% } else if (!hasGamelogData) { %>
        <p class="dfs-slate-status dfs-slate-status--past">Scoring data isn’t available yet.</p>
        <% } else { %>
        <p class="dfs-slate-status dfs-slate-status--past" id="weeklyGamelogGap" <%= slateHasBoxScoresForWeek ? 'hidden' : '' %> role="status">
          <% if (!slateHasBoxScoresForWeek) { %>Game results don’t cover this slate’s dates yet — scores stay at zero until those games are in the sheet.<% } %>
        </p>
        <% if (serverRendered && weeklyStandings && weeklyStandings.weekly) { %>
        <p class="dfs-slate-status dfs-slate-status--past" id="weeklyEntryCount">
          <%= weeklyStandings.weekly.entryCount %> saved lineup<%= weeklyStandings.weekly.entryCount === 1 ? '' : 's' %>
        </p>
        <% } else { %>
        <p class="dfs-slate-status dfs-slate-status--past" id="weeklyEntryCount" hidden></p>
        <% } %>
        <% } %>
      </section>
      <% } %>

      <div class="dfs-leaderboard-table-wrap">
        <table class="dfs-leaderboard-table page-table">
          <thead>
            <tr>
              <th scope="col">Rank</th>
              <th scope="col">Player</th>
              <th scope="col">Points</th>
              <% if (lbSlateLocked) { %><th scope="col">Salary at save</th><% } %>
            </tr>
          </thead>
          <tbody id="leaderboardWeeklyBody">
            <% if (serverRendered && weeklyStandings && weeklyStandings.weekly) {
              const rows = weeklyStandings.weekly.rows || [];
              if (!rows.length) { %>
            <tr>
              <td colspan="<%= tableColspan %>" class="dfs-leaderboard-empty">
                <% if (slate && slate.isPast && hasGamelogData && !slateHasBoxScoresForWeek) { %>
                Game results don’t cover this slate’s scheduled dates yet — fantasy scores stay at zero until those games are reflected.<br/><br/>
                <% } %>
                No saved lineups for this slate yet — when players save a lineup here, they’ll show up ranked by points.
              </td>
            </tr>
            <% } else { rows.forEach((row) => { %>
            <tr>
              <td><%= row.rankDisplay != null ? row.rankDisplay : row.rank %></td>
              <td>
                <% if (lbSlateLocked && row.userId) { %>
                <a href="/dfs/leaderboard/lineup?week=<%= encodeURIComponent(selectedWeek) %>&amp;user=<%= encodeURIComponent(row.userId) %>" class="dfs-leaderboard-player-link"><%= row.displayName %></a>
                <% } else { %><%= row.displayName %><% } %>
              </td>
              <td class="dfs-leaderboard-pts"><% if (row.points == null) { %>—<% } else { %><strong><%= row.points %></strong><% } %></td>
              <% if (lbSlateLocked) { %><td>$<%= (row.salaryUsed || 0).toLocaleString() %></td><% } %>
            </tr>
            <% }); } } else { %>
            <tr>
              <td colspan="<%= tableColspan %>" class="dfs-leaderboard-empty">Loading…</td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <section class="dfs-scoring-rules">
        <h2 class="section-heading">Scoring</h2>
        <ul class="dfs-rules-list">
          <li>Single: <%= scoringRules.single %> pts</li>
          <li>Double: <%= scoringRules.double %> pts</li>
          <li>Triple: <%= scoringRules.triple %> pts</li>
          <li>Home run: <%= scoringRules.hr %> pts</li>
          <li>RBI: <%= scoringRules.rbi %> pts</li>
          <li>Run: <%= scoringRules.run %> pts</li>
          <li>Walk: <%= scoringRules.walk %> pts</li>
        </ul>
      </section>
    </main>

    <% if (canLoadStandings && !serverRendered) { %>
    <script>
      window.__FIREBASE_CONFIG__ = <%- JSON.stringify(firebaseClientConfig || null) %>;
      window.__MMS_CAREER_CSV_URL__ = "<%= sitePath('/data/csv/career.csv') %>";
      window.__LEADERBOARD_PAGE__ = <%- JSON.stringify({
        selectedWeek: selectedWeek,
        leaderboardServerRead: typeof leaderboardServerRead !== 'undefined' ? leaderboardServerRead : false,
        serverRendered: false,
        useClientScoring: typeof useClientScoring !== 'undefined' ? useClientScoring : true,
        slateLocked: lbSlateLocked,
        slate: slate ? { label: slate.label, isPast: slate.isPast, viewToken: slate.viewToken, slateType: slate.slateType, canEdit: slate.canEdit === true, isLocked: slate.canEdit !== true } : null
      }) %>;
    </script>
    <script>
      window.addEventListener("error", function (ev) {
        var src = ev.filename || "";
        if (src.indexOf("dfs-leaderboard") === -1) return;
        var screen = document.getElementById("leaderboardLoadingScreen");
        if (screen) screen.hidden = true;
        document.body.classList.add("leaderboard-ready");
        var status = document.getElementById("leaderboardStatus");
        if (status) {
          status.hidden = false;
          status.className = "dfs-leaderboard-alert dfs-leaderboard-alert--error";
          status.innerHTML =
            "<p>Leaderboard script failed to load. Hard-refresh (Cmd+Shift+R) or check the browser console.</p>";
        }
      });
    </script>
    <script type="module" src="<%= sitePath('/js/dfs-leaderboard.js') %>?v=<%= assetVersion %>"></script>
    <% } %>
  </body>
</html>
