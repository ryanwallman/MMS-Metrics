<header class="site-header">
  <div class="site-header-inner">
    <div class="site-header-top">
      <div class="site-brand-block">
        <a href="<%= sitePath('/') %>" class="site-brand">
          <img
            src="<%= sitePath('/mms-stats-logo.png') %>?v=<%= assetVersion %>"
            alt="MMS Stats"
            class="site-brand-logo"
            width="80"
            height="80"
            decoding="async"
          />
          <span class="site-brand-text">Marlboro Men's Softball</span>
        </a>
      </div>
      <button
        type="button"
        class="site-nav-toggle"
        aria-expanded="false"
        aria-controls="site-main-nav"
      >
        <span class="site-sr-only">Menu</span>
        <span class="site-nav-toggle-bars" aria-hidden="true"></span>
      </button>
    </div>
    <nav id="site-main-nav" class="site-nav" aria-label="Main">
      <% (typeof siteNav !== "undefined" ? siteNav : []).forEach((item) => { %>
      <a
        href="<%= item.href %>"
        class="site-nav-link<%= typeof navActive !== "undefined" && navActive === item.id ? " is-active" : "" %>"
        <%= typeof navActive !== "undefined" && navActive === item.id ? 'aria-current="page"' : "" %>
      >
        <%= item.label %>
      </a>
      <% }) %>
    </nav>
    <div class="site-header-meta">
      <% if (typeof generatedAt !== "undefined" && generatedAt) { %>
      <p class="site-updated">
        Data updated
        <time datetime="<%= generatedAt %>"><%= typeof dataUpdatedLabel !== "undefined" ? dataUpdatedLabel : generatedAt %></time>
      </p>
      <% } %>
      <% if (typeof siteDisclaimer !== "undefined" && siteDisclaimer) { %>
      <p class="site-disclaimer"><%= siteDisclaimer %></p>
      <% } %>
    </div>
  </div>
</header>
