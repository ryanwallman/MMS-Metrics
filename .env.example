# Copy to .env and fill from Firebase Console → Project settings → Your apps (Web)
# Used for Firestore (lineup save + leaderboard). Google sign-in is not required.
# After deploying to https://mmsmetrics.com, add mmsmetrics.com (and www) under
# Firebase Console → Authentication → Settings → Authorized domains.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
# Optional
FIREBASE_MEASUREMENT_ID=

# Optional: override Google Sheets CSV export URLs (defaults in lib/dataPaths.js)
# GAMELOGS_2026_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=...
# STATS_2026_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=...

# Leaderboard (server reads all lineups via Admin SDK)
# Download JSON from Firebase Console → Project settings → Service accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase/service-account.json
# Or paste the full JSON on one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
